          "hasOfferCatalog": {
            "@type": "OfferCatalog",
            "name": "Servicii proiectare infrastructură",
            "itemListElement": [
              {
                "@type": "Offer",
                "itemOffered": {
                  "@type": "Service",
                  "name": "Proiectare Drumuri",
                  "description": "Proiectare drumuri municipale, județene, naționale, intersecții, sensuri giratorii, parcări și piste de biciclete.",
                  "url": "https://me-design.ro/servicii/proiectare-drumuri"
                }
              },
              {
                "@type": "Offer",
                "itemOffered": {
                  "@type": "Service",
                  "name": "Proiectare Poduri, Pasaje, Pasarele",
                  "description": "Proiectare poduri rutiere și pietonale, pasaje, pasarele pentru pietoni și bicicliști, podețe.",
                  "url": "https://me-design.ro/servicii/proiectare-poduri-pasaje"
                }
              },
              {
                "@type": "Offer",
                "itemOffered": {
                  "@type": "Service",
                  "name": "Lucrări de Sprijin și Consolidări",
                  "description": "Proiectare ziduri de sprijin, consolidare versanți, stabilizare teren, gabioane, ancore.",
                  "url": "https://me-design.ro/servicii/lucrari-consolidare"
                }
