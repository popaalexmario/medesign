            "email": "office@me-design.ro",
            "availableLanguage": "Romanian"
          },
          "sameAs": []
        },
        {
          "@type": "LocalBusiness",
          "@id": "https://me-design.ro/#localbusiness",
          "name": "Mario Engineering Design SRL",
          "description": "Servicii profesionale de proiectare infrastructură: drumuri, poduri, pasaje, pasarele și lucrări de sprijin și consolidări în România.",
          "url": "https://me-design.ro",
          "telephone": "+40746784156",
          "email": "office@me-design.ro",
          "address": {
            "@type": "PostalAddress",
            "addressCountry": "RO",
            "addressRegion": "România"
          },
