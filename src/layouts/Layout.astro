---
import CookieConsent from '../components/CookieConsent.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'ME Design - Servicii profesionale de proiectare infrastructură: drumuri, poduri, pasaje, pasarele și lucrări de sprijin și consolidări.' } = Astro.props;
---

<!doctype html>
<html lang="ro">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />

    <link rel="stylesheet" href="https://unpkg.com/aos@2.3.1/dist/aos.css" />

    <link rel="icon" type="image/x-icon" href="/img/favicon.ico" />
    <title>{title} | ME Design</title>

    <style is:global>
      *, *::before, *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: 'Inter', system-ui, sans-serif;
        color: #1e293b;
        line-height: 1.6;
        overflow-x: hidden;
      }

      h1, h2, h3, h4, h5, h6 {
        font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
        line-height: 1.2;
      }

      .glass-card {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.8);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.08);
      }

      .glass-dark {
        background: rgba(30, 58, 95, 0.05);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(30, 58, 95, 0.1);
      }

      .gradient-text {
        background: linear-gradient(135deg, #1e3a5f, #d97706);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .section-padding {
        padding: 3rem 0;
      }

      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1.5rem;
      }

      /* Blueprint grid animation */
      @keyframes drawGrid {
        0% { opacity: 0; stroke-dashoffset: 1000; }
        50% { opacity: 0.06; }
        100% { opacity: 0.06; stroke-dashoffset: 0; }
      }

      @keyframes drawPath {
        to { stroke-dashoffset: 0; }
      }

      @keyframes fadeSlideUp {
        from { opacity: 0; transform: translateY(40px); }
        to { opacity: 1; transform: translateY(0); }
      }

      @keyframes fadeSlideRight {
        from { opacity: 0; transform: translateX(-30px); }
        to { opacity: 1; transform: translateX(0); }
      }

      @keyframes countPulse {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.05); }
      }

      @keyframes shimmer {
        0% { background-position: -200% 0; }
        100% { background-position: 200% 0; }
      }

      @keyframes floatSlow {
        0%, 100% { transform: translateY(0) rotate(0deg); }
        33% { transform: translateY(-15px) rotate(1deg); }
        66% { transform: translateY(-8px) rotate(-1deg); }
      }

      @keyframes progressLine {
        from { width: 0; }
        to { width: 100%; }
      }

      @keyframes rotateShape {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
      }

      @keyframes morphBlob {
        0%, 100% { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; }
        50% { border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%; }
      }

      .animate-draw-path {
        animation: drawPath 2s ease-out forwards;
      }

      .animate-float-slow {
        animation: floatSlow 8s ease-in-out infinite;
      }

      .animate-morph {
        animation: morphBlob 8s ease-in-out infinite;
      }

      .animate-rotate-slow {
        animation: rotateShape 30s linear infinite;
      }

      .animate-shimmer {
        background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.1) 50%, transparent 100%);
        background-size: 200% 100%;
        animation: shimmer 3s ease-in-out infinite;
      }

      /* Tilt card effect */
      .tilt-card {
        transform-style: preserve-3d;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
      }

      .tilt-card:hover {
        box-shadow: 0 25px 50px rgba(0, 0, 0, 0.12);
      }

      .tilt-card .tilt-inner {
        transform: translateZ(30px);
      }

      /* Counter animation glow */
      .counter-glow {
        text-shadow: 0 0 40px rgba(217, 119, 6, 0.3);
      }

      /* Timeline connector */
      .timeline-connector {
        position: relative;
      }

      .timeline-connector::after {
        content: '';
        position: absolute;
        top: 50%;
        left: 100%;
        width: calc(100% - 2rem);
        height: 2px;
        background: linear-gradient(90deg, #d97706, #1e3a5f);
        opacity: 0;
        transform: scaleX(0);
        transform-origin: left;
        transition: transform 0.8s ease, opacity 0.3s;
      }

      .timeline-connector.animated::after {
        opacity: 0.3;
        transform: scaleX(1);
      }

      /* Parallax container */
      .parallax-layer {
        will-change: transform;
        transition: transform 0.1s linear;
      }

      /* Hero photo parallax */
      .hero-parallax {
        will-change: transform;
        transition: transform 0.15s ease-out;
      }

      /* Hero blueprint grid fade in */
      .hero-grid-fade {
        opacity: 0;
        animation: fadeInSlow 2s ease-out 1s forwards;
      }

      @keyframes fadeInSlow {
        to { opacity: 1; }
      }

      /* Hero road trace */
      .hero-trace {
        animation: drawHeroTrace 3s ease-out 1.5s forwards;
      }

      .hero-trace-2 {
        animation: drawHeroTrace 2.5s ease-out 2s forwards;
      }

      @keyframes drawHeroTrace {
        to { stroke-dashoffset: 0; }
      }

      /* Hero annotations */
      .hero-annotation {
        opacity: 0;
        animation: fadeSlideAnnotation 0.8s ease-out forwards;
        animation-delay: var(--delay, 3s);
      }

      @keyframes fadeSlideAnnotation {
        from { opacity: 0; transform: translateY(5px); }
        to { opacity: 1; transform: translateY(0); }
      }

      /* Cross section panel */
      .hero-cross-section {
        opacity: 0;
        transform: translateX(30px);
        animation: slideInPanel 0.8s ease-out 4.5s forwards;
      }

      @keyframes slideInPanel {
        to { opacity: 1; transform: translateX(0); }
      }

      /* Road plan view layers - draw in */
      .road-layer {
        stroke-dasharray: 1200;
        stroke-dashoffset: 1200;
        opacity: 0;
        animation: drawRoadLayer 2s ease-out forwards;
        animation-delay: var(--delay, 1s);
      }

      @keyframes drawRoadLayer {
        0% { stroke-dashoffset: 1200; opacity: 0; }
        10% { opacity: 1; }
        100% { stroke-dashoffset: 0; opacity: 1; }
      }

      .road-text {
        opacity: 0;
        animation: fadeInText 0.6s ease-out forwards;
        animation-delay: var(--delay, 1s);
      }

      @keyframes fadeInText {
        from { opacity: 0; }
        to { opacity: 1; }
      }

      /* Cross section layers - reveal from bottom up */
      .layer-reveal {
        opacity: 0;
        transform-origin: center bottom;
        animation: revealLayer 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        animation-delay: var(--delay, 1s);
      }

      @keyframes revealLayer {
        0% { opacity: 0; transform: translateY(8px) scaleY(0.8); }
        100% { opacity: 1; transform: translateY(0) scaleY(1); }
      }
    </style>
  </head>
  <body class="bg-white">
    <slot />
    <CookieConsent />

    <script is:inline src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script is:inline>
      AOS.init({
        duration: 700,
        once: true,
        offset: 50,
        easing: 'ease-out-cubic',
      });
    </script>
  <!-- Cloudflare Web Analytics -->
  <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "bdb3f1be23d14cee9307a78d57f3bf39"}'></script>
  <!-- End Cloudflare Web Analytics -->
  </body>
</html>
