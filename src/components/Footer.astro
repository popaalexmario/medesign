---
const currentYear = new Date().getFullYear();

const services = [
  { label: 'Proiectare drumuri', href: '/servicii#proiectare-drumuri' },
  { label: 'Proiectare poduri, pasaje, pasarele', href: '/servicii#proiectare-poduri' },
  { label: 'Lucrări de sprijin și consolidări', href: '/servicii#lucrari-sprijin-consolidari' },
];

const links = [
  { label: 'Despre noi', href: '/despre' },
  { label: 'Portofoliu', href: '/portofoliu' },
  { label: 'Contact', href: '/contact' },
];
---

<footer class="bg-brand-900 text-white">
  <div class="container">
    <div class="py-16 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <div class="lg:col-span-1">
        <div class="mb-4">
          <img src="/img/logo-brand.png" alt="Mario Engineering Design SRL" class="h-14 w-auto object-contain brightness-0 invert" />
        </div>
        <p class="text-white/50 text-[14px] leading-relaxed max-w-xs">
          Mario Engineering Design SRL — Proiectare Infrastructură România. Servicii profesionale cu experiență dovedită în proiecte de anvergură.
        </p>
      </div>

      <div>
        <h4 class="font-heading font-semibold text-[15px] mb-4 text-white/80 uppercase tracking-wider">Servicii</h4>
        <ul class="space-y-2.5">
          {services.map((item) => (
            <li>
              <a href={item.href} class="text-white/50 hover:text-accent-400 text-[14px] transition-colors">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-heading font-semibold text-[15px] mb-4 text-white/80 uppercase tracking-wider">Companie</h4>
        <ul class="space-y-2.5">
          {links.map((item) => (
            <li>
              <a href={item.href} class="text-white/50 hover:text-accent-400 text-[14px] transition-colors">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-heading font-semibold text-[15px] mb-4 text-white/80 uppercase tracking-wider">Contact</h4>
        <ul class="space-y-3 text-[14px]">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-accent-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-white/50">România</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-accent-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:office@me-design.ro" class="text-white/50 hover:text-accent-400 transition-colors">office@me-design.ro</a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-accent-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href="tel:+40746784156" class="text-white/50 hover:text-accent-400 transition-colors">+40 746 784 156</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/10 py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-white/30 text-[13px]">
        &copy; {currentYear} Mario Engineering Design SRL. Toate drepturile rezervate.
      </p>
      <p class="text-white/20 text-[12px]">
        Proiectat cu profesionalism
      </p>
    </div>
  </div>
</footer>
