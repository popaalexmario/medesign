---
const currentYear = new Date().getFullYear();

const services = [
  { label: 'Proiectare drumuri', href: '/servicii/proiectare-drumuri' },
  { label: 'Rețele edilitare', href: '/servicii/retele-edilitare' },
  { label: 'Studii de fezabilitate', href: '/servicii/studii-fezabilitate' },
  { label: 'Asistență tehnică', href: '/servicii/asistenta-tehnica' },
];

const links = [
  { label: 'Despre noi', href: '/despre' },
  { label: 'Portofoliu', href: '/portofoliu' },
  { label: 'Contact', href: '/contact' },
];
---

<footer class="bg-brand-900 text-white">
  <div class="container">
    <div class="py-16 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <div class="lg:col-span-1">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 bg-accent-500 rounded-lg flex items-center justify-center">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          <span class="font-heading font-bold text-xl">MeDesign</span>
        </div>
        <p class="text-white/50 text-[14px] leading-relaxed max-w-xs">
          MeDesign — Proiectare Infrastructură România. Servicii profesionale cu experiență dovedită în proiecte de anvergură.
        </p>
      </div>

      <div>
        <h4 class="font-heading font-semibold text-[15px] mb-4 text-white/80 uppercase tracking-wider">Servicii</h4>
        <ul class="space-y-2.5">
          {services.map((item) => (
            <li>
              <a href={item.href} class="text-white/50 hover:text-accent-400 text-[14px] transition-colors">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-heading font-semibold text-[15px] mb-4 text-white/80 uppercase tracking-wider">Companie</h4>
        <ul class="space-y-2.5">
          {links.map((item) => (
            <li>
              <a href={item.href} class="text-white/50 hover:text-accent-400 text-[14px] transition-colors">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-heading font-semibold text-[15px] mb-4 text-white/80 uppercase tracking-wider">Contact</h4>
        <ul class="space-y-3 text-[14px]">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-accent-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-white/50">România</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-accent-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:office@me-design.ro" class="text-white/50 hover:text-accent-400 transition-colors">office@me-design.ro</a>
          </li>

        </ul>
      </div>
    </div>

    <div class="border-t border-white/10 py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-white/30 text-[13px]">
        &copy; {currentYear} MeDesign. Toate drepturile rezervate.
      </p>
      <p class="text-white/20 text-[12px]">
        Proiectat cu profesionalism
      </p>
    </div>
  </div>
</footer>
