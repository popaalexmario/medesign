---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Lucrări de Sprijin și Consolidări — Versanți, Taluzuri, Ziduri"
  description="Proiectare lucrări de sprijin și consolidare în România: ziduri de sprijin, consolidare versanți și taluzuri, stabilizare teren, gabioane, ancore. Protejarea infrastructurii împotriva alunecărilor."
>
  <Header />

  <section class="pt-28 pb-8 bg-gradient-to-br from-brand-900 to-brand-700">
    <div class="container">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-white/50 text-[13px] mb-6" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Acasă</a>
        <span>/</span>
        <a href="/servicii" class="hover:text-white transition-colors">Servicii</a>
        <span>/</span>
        <span class="text-white">Lucrări de Sprijin și Consolidări</span>
      </nav>
      <span class="text-accent-400 font-semibold text-[13px] uppercase tracking-widest" data-aos="fade-up">Serviciu</span>
      <h1 class="text-[36px] md:text-[52px] font-heading font-extrabold text-white mt-3" data-aos="fade-up" data-aos-delay="50">
        Lucrări de Sprijin<br />și Consolidări
      </h1>
      <p class="text-white/60 text-[17px] mt-4 max-w-xl" data-aos="fade-up" data-aos-delay="100">
        Soluții tehnice pentru stabilizarea terenurilor instabile și protejarea infrastructurii împotriva alunecărilor și eroziunii.
      </p>
    </div>
  </section>

  <section class="section-padding bg-white">
    <div class="container">
      <div class="grid lg:grid-cols-3 gap-12">
        <!-- Main content -->
        <div class="lg:col-span-2 space-y-8">
          <div data-aos="fade-up">
            <img src="/img/projects/consolidare%20autostrada.jpg" alt="Lucrări de sprijin și consolidări" class="w-full rounded-2xl object-cover max-h-72" />
          </div>
          <div data-aos="fade-up">
            <h2 class="text-[26px] font-heading font-bold text-brand-800 mb-4">Proiectare consolidare versanți și taluzuri</h2>
            <p class="text-steel-500 text-[15px] leading-relaxed mb-4">
              ME Design proiectează lucrări de sprijin și consolidare pentru terenuri instabile, taluzuri și versanți afectați de alunecări, eroziune sau suprasarcini. Oferim soluții tehnice complete, de la investigarea cauzelor instabilității până la proiectarea și supravegherea execuției lucrărilor.
            </p>
            <p class="text-steel-500 text-[15px] leading-relaxed mb-4">
              Specializarea noastră acoperă atât lucrările de sprijin pentru infrastructura rutieră existentă sau nouă, cât și consolidarea terenurilor în zonele cu risc geotehnic ridicat. Colaborăm cu geotehnicieni autorizați pentru investigații de teren și elaborăm soluțiile optime tehnic și economic.
            </p>
            <p class="text-steel-500 text-[15px] leading-relaxed">
              Documentațiile noastre sunt elaborate conform normativelor NP 124, P 70, NP 112 și a ghidurilor tehnice aplicabile, asigurând conformitatea cu cerințele de autorizare și execuție.
            </p>
          </div>

          <div data-aos="fade-up">
            <h2 class="text-[22px] font-heading font-bold text-brand-800 mb-4">Tipuri de lucrări de consolidare</h2>
            <div class="grid sm:grid-cols-2 gap-4">
              {[
                { title: 'Ziduri de sprijin', desc: 'Ziduri din beton armat, beton ciclopian sau zidărie de piatră pentru susținerea taluzurilor și a terenurilor adiacente drumurilor.' },
                { title: 'Consolidări de versanți', desc: 'Soluții complexe pentru stabilizarea versanților afectați de alunecări de teren, cu ancoraje și rețele de protecție.' },
                { title: 'Consolidări de taluzuri', desc: 'Proiectare lucrări de consolidare a taluzurilor de debleu și rambleu pentru drumuri și căi ferate.' },
                { title: 'Gabioane', desc: 'Structuri flexibile din coșuri metalice umplute cu piatră — soluție economică și ecologică pentru sprijiniri și protecții de maluri.' },
                { title: 'Ancore și micropiloti', desc: 'Sisteme de ancorare profundă a terenului pentru stabilizarea structurilor și masivelor de pământ.' },
                { title: 'Protecții de maluri', desc: 'Lucrări de protecție a malurilor cursurilor de apă împotriva eroziunii hidraulice, inclusiv gabioane și beton proiectat.' },
              ].map((item) => (
                <div class="bg-steel-50 rounded-2xl p-5 border border-steel-100">
                  <div class="flex items-start gap-3">
                    <svg class="w-5 h-5 text-accent-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    <div>
                      <p class="font-semibold text-brand-800 text-[14px]">{item.title}</p>
                      <p class="text-steel-500 text-[13px] mt-1">{item.desc}</p>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- FAQ -->
          <div data-aos="fade-up">
            <h2 class="text-[22px] font-heading font-bold text-brand-800 mb-4">Întrebări frecvente</h2>
            <div class="space-y-4">
              {[
                {
                  q: 'Când este necesară o lucrare de consolidare a unui versant?',
                  a: 'O lucrare de consolidare este necesară când se constată semne de instabilitate a terenului: fisuri în teren sau construcții, tasări, deplasări vizibile ale masivului de pământ sau când urmează să se construiască infrastructură în zone cu risc geotehnic.'
                },
                {
                  q: 'Ce investigații sunt necesare înainte de proiectarea consolidărilor?',
                  a: 'Sunt necesare: studiu geotehnic detaliat (foraje, sondaje), studiu topografic, monitorizare deplasări (dacă există) și, în unele cazuri, studiu hidrologic. ME Design coordonează aceste investigații prin colaboratori specializați.'
                },
                {
                  q: 'Ce este mai avantajos: zid de sprijin din beton sau gabioane?',
                  a: 'Depinde de condițiile specifice ale amplasamentului. Gabioanele sunt mai economice, flexibile și ecologice, dar zidurile din beton armat sunt mai rezistente și necesită mai puțin spațiu. Vom recomanda soluția optimă după analiza condițiilor de teren.'
                },
              ].map((item) => (
                <div class="border border-steel-100 rounded-2xl p-5">
                  <p class="font-semibold text-brand-800 text-[15px] mb-2">{item.q}</p>
                  <p class="text-steel-500 text-[14px] leading-relaxed">{item.a}</p>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-6" data-aos="fade-up">
          <div class="bg-brand-900 rounded-3xl p-6 text-white sticky top-28">
            <h3 class="font-heading font-bold text-[18px] mb-2">Solicită o consultanță gratuită</h3>
            <p class="text-white/60 text-[14px] mb-5">Contactează-ne pentru o evaluare a proiectului tău.</p>
            <a href="/contact" class="block text-center bg-accent-500 hover:bg-accent-600 text-white px-6 py-3 rounded-full font-semibold text-[14px] transition-all">
              Solicită ofertă
            </a>
            <div class="mt-5 pt-5 border-t border-white/10 space-y-3">
              <a href="tel:+40746784156" class="flex items-center gap-3 text-white/70 hover:text-white text-[14px] transition-colors">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                +40 746 784 156
              </a>
              <a href="mailto:office@me-design.ro" class="flex items-center gap-3 text-white/70 hover:text-white text-[14px] transition-colors">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                office@me-design.ro
              </a>
            </div>
          </div>

          <div class="bg-steel-50 rounded-3xl p-6">
            <h3 class="font-heading font-bold text-brand-800 text-[16px] mb-4">Alte servicii</h3>
            <div class="space-y-3">
              <a href="/servicii/proiectare-drumuri" class="flex items-center gap-3 text-steel-600 hover:text-brand-600 text-[14px] transition-colors group">
                <svg class="w-4 h-4 shrink-0 text-brand-400 group-hover:text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                Proiectare drumuri și platforme
              </a>
              <a href="/servicii/proiectare-poduri-pasaje" class="flex items-center gap-3 text-steel-600 hover:text-brand-600 text-[14px] transition-colors group">
                <svg class="w-4 h-4 shrink-0 text-brand-400 group-hover:text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                Proiectare poduri, pasaje, pasarele
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Schema.org -->
  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Când este necesară o lucrare de consolidare a unui versant?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "O lucrare de consolidare este necesară când se constată semne de instabilitate a terenului: fisuri în teren sau construcții, tasări, deplasări vizibile ale masivului de pământ sau când urmează să se construiască infrastructură în zone cu risc geotehnic."
        }
      },
      {
        "@type": "Question",
        "name": "Ce investigații sunt necesare înainte de proiectarea consolidărilor?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Sunt necesare: studiu geotehnic detaliat (foraje, sondaje), studiu topografic, monitorizare deplasări (dacă există) și, în unele cazuri, studiu hidrologic. ME Design coordonează aceste investigații prin colaboratori specializați."
        }
      },
      {
        "@type": "Question",
        "name": "Ce este mai avantajos: zid de sprijin din beton sau gabioane?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Depinde de condițiile specifice ale amplasamentului. Gabioanele sunt mai economice, flexibile și ecologice, dar zidurile din beton armat sunt mai rezistente și necesită mai puțin spațiu. Vom recomanda soluția optimă după analiza condițiilor de teren."
        }
      }
    ]
  }
  </script>

  <Footer />
</Layout>
