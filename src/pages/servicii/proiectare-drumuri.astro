---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Proiectare Drumuri — Municipale, Județene, Naționale"
  description="Servicii complete de proiectare drumuri în România: drumuri comunale, județene, naționale, intersecții, sensuri giratorii, parcări și piste de biciclete. Documentații tehnice complete."
>
  <Header />

  <section class="pt-28 pb-8 bg-gradient-to-br from-brand-900 to-brand-700">
    <div class="container">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-white/50 text-[13px] mb-6" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Acasă</a>
        <span>/</span>
        <a href="/servicii" class="hover:text-white transition-colors">Servicii</a>
        <span>/</span>
        <span class="text-white">Proiectare Drumuri</span>
      </nav>
      <span class="text-accent-400 font-semibold text-[13px] uppercase tracking-widest" data-aos="fade-up">Serviciu</span>
      <h1 class="text-[36px] md:text-[52px] font-heading font-extrabold text-white mt-3" data-aos="fade-up" data-aos-delay="50">
        Proiectare Drumuri<br />în România
      </h1>
      <p class="text-white/60 text-[17px] mt-4 max-w-xl" data-aos="fade-up" data-aos-delay="100">
        Proiecte tehnice complete pentru drumuri comunale, județene și naționale — de la studii de fezabilitate la detalii de execuție.
      </p>
    </div>
  </section>

  <section class="section-padding bg-white">
    <div class="container">
      <div class="grid lg:grid-cols-3 gap-12">
        <!-- Main content -->
        <div class="lg:col-span-2 space-y-8">
          <div data-aos="fade-up">
            <h2 class="text-[26px] font-heading font-bold text-brand-800 mb-4">Documentații complete pentru proiectare drumuri</h2>
            <p class="text-steel-500 text-[15px] leading-relaxed mb-4">
              ME Design oferă servicii integrate de proiectare pentru toate categoriile de drumuri publice din România, conform normativelor tehnice în vigoare (AND, SR, STAS). Echipa noastră acoperă întreg procesul de proiectare — de la studii preliminare și investigații de teren până la documentațiile necesare pentru autorizația de construire și proiectul de execuție.
            </p>
            <p class="text-steel-500 text-[15px] leading-relaxed mb-4">
              Fiecare proiect de drum este tratat individual, ținând cont de condițiile specifice ale terenului, volumul de trafic estimat, cerințele beneficiarului și reglementările locale și naționale. Colaborăm cu primării, consilii județene, beneficiari privați și constructori din toată țara.
            </p>
            <p class="text-steel-500 text-[15px] leading-relaxed">
              Asigurăm documentații complete în toate fazele: Studiu de Fezabilitate (SF), Documentație de Avizare a Lucrărilor de Intervenții (DALI), Proiect Tehnic (PT) și Detalii de Execuție (DDE), inclusiv asistență tehnică pe parcursul execuției.
            </p>
          </div>

          <div data-aos="fade-up">
            <h2 class="text-[22px] font-heading font-bold text-brand-800 mb-4">Tipuri de lucrări</h2>
            <div class="grid sm:grid-cols-2 gap-4">
              {[
                { title: 'Drumuri comunale și județene', desc: 'Modernizare, reabilitare și extindere drumuri locale cu finanțare din fonduri europene sau buget local.' },
                { title: 'Drumuri naționale', desc: 'Proiectare și reabilitare drumuri naționale în conformitate cu normativele DRDP și CNAIR.' },
                { title: 'Intersecții și sensuri giratorii', desc: 'Amenajare intersecții la nivel, sensuri giratorii, pasaje denivelate pentru fluența traficului.' },
                { title: 'Parcări și platforme', desc: 'Proiectare parcări publice și private, platforme industriale, drumuri de acces.' },
                { title: 'Piste de biciclete', desc: 'Amenajare piste ciclabile urbane și interurbane, cu sisteme de semnalizare specifice.' },
                { title: 'Lucrări de artă', desc: 'Podețe, rigole, canalizare pluvială, semaforizare — integrate în proiectul de drum.' },
              ].map((item) => (
                <div class="bg-steel-50 rounded-2xl p-5 border border-steel-100">
                  <div class="flex items-start gap-3">
                    <svg class="w-5 h-5 text-accent-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    <div>
                      <p class="font-semibold text-brand-800 text-[14px]">{item.title}</p>
                      <p class="text-steel-500 text-[13px] mt-1">{item.desc}</p>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- FAQ -->
          <div data-aos="fade-up">
            <h2 class="text-[22px] font-heading font-bold text-brand-800 mb-4">Întrebări frecvente</h2>
            <div class="space-y-4">
              {[
                {
                  q: 'Ce documente sunt necesare pentru un proiect de drum?',
                  a: 'Sunt necesare: extrasul de carte funciară, planul topografic actualizat, studiul geotehnic și, după caz, studiul de trafic. ME Design poate coordona obținerea acestora prin colaboratori autorizați.'
                },
                {
                  q: 'Cât durează elaborarea unui proiect tehnic de drum?',
                  a: 'În funcție de complexitate, un Proiect Tehnic complet pentru un drum județean de 5-10 km durează între 3 și 6 luni. Studiul de Fezabilitate poate fi finalizat în 4-8 săptămâni.'
                },
                {
                  q: 'Proiectați și drumuri cu finanțare europeană?',
                  a: 'Da, avem experiență cu documentații pentru proiecte finanțate din PNRR, POR, POIM și alte programe europene, inclusiv documentațiile specifice cerute de finanțatori.'
                },
              ].map((item) => (
                <div class="border border-steel-100 rounded-2xl p-5">
                  <p class="font-semibold text-brand-800 text-[15px] mb-2">{item.q}</p>
                  <p class="text-steel-500 text-[14px] leading-relaxed">{item.a}</p>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-6" data-aos="fade-up">
          <div class="bg-brand-900 rounded-3xl p-6 text-white sticky top-28">
            <h3 class="font-heading font-bold text-[18px] mb-2">Solicită o consultanță gratuită</h3>
            <p class="text-white/60 text-[14px] mb-5">Contactează-ne pentru o evaluare a proiectului tău.</p>
            <a href="/contact" class="block text-center bg-accent-500 hover:bg-accent-600 text-white px-6 py-3 rounded-full font-semibold text-[14px] transition-all">
              Solicită ofertă
            </a>
            <div class="mt-5 pt-5 border-t border-white/10 space-y-3">
              <a href="tel:+40746784156" class="flex items-center gap-3 text-white/70 hover:text-white text-[14px] transition-colors">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                +40 746 784 156
              </a>
              <a href="mailto:office@me-design.ro" class="flex items-center gap-3 text-white/70 hover:text-white text-[14px] transition-colors">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                office@me-design.ro
              </a>
            </div>
          </div>

          <div class="bg-steel-50 rounded-3xl p-6">
            <h3 class="font-heading font-bold text-brand-800 text-[16px] mb-4">Alte servicii</h3>
            <div class="space-y-3">
              <a href="/servicii/proiectare-poduri-pasaje" class="flex items-center gap-3 text-steel-600 hover:text-brand-600 text-[14px] transition-colors group">
                <svg class="w-4 h-4 shrink-0 text-brand-400 group-hover:text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                Proiectare poduri, pasaje, pasarele
              </a>
              <a href="/servicii/lucrari-consolidare" class="flex items-center gap-3 text-steel-600 hover:text-brand-600 text-[14px] transition-colors group">
                <svg class="w-4 h-4 shrink-0 text-brand-400 group-hover:text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                Lucrări de sprijin și consolidări
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Schema.org -->
  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Ce documente sunt necesare pentru un proiect de drum?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Sunt necesare: extrasul de carte funciară, planul topografic actualizat, studiul geotehnic și, după caz, studiul de trafic. ME Design poate coordona obținerea acestora prin colaboratori autorizați."
        }
      },
      {
        "@type": "Question",
        "name": "Cât durează elaborarea unui proiect tehnic de drum?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "În funcție de complexitate, un Proiect Tehnic complet pentru un drum județean de 5-10 km durează între 3 și 6 luni. Studiul de Fezabilitate poate fi finalizat în 4-8 săptămâni."
        }
      },
      {
        "@type": "Question",
        "name": "Proiectați și drumuri cu finanțare europeană?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Da, avem experiență cu documentații pentru proiecte finanțate din PNRR, POR, POIM și alte programe europene, inclusiv documentațiile specifice cerute de finanțatori."
        }
      }
    ]
  }
  </script>

  <Footer />
</Layout>
