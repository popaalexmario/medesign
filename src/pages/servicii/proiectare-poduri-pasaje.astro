---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout
  title="Proiectare Poduri, Pasaje și Pasarele"
  description="Proiectare poduri rutiere și pietonale, pasaje denivelate, pasarele pentru pietoni și bicicliști, podețe. Soluții tehnice adaptate pentru traversări peste cursuri de apă, căi ferate și artere rutiere."
>
  <Header />

  <section class="pt-28 pb-8 bg-gradient-to-br from-brand-900 to-brand-700">
    <div class="container">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-white/50 text-[13px] mb-6" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white transition-colors">Acasă</a>
        <span>/</span>
        <a href="/servicii" class="hover:text-white transition-colors">Servicii</a>
        <span>/</span>
        <span class="text-white">Proiectare Poduri, Pasaje, Pasarele</span>
      </nav>
      <span class="text-accent-400 font-semibold text-[13px] uppercase tracking-widest" data-aos="fade-up">Serviciu</span>
      <h1 class="text-[36px] md:text-[52px] font-heading font-extrabold text-white mt-3" data-aos="fade-up" data-aos-delay="50">
        Proiectare Poduri,<br />Pasaje și Pasarele
      </h1>
      <p class="text-white/60 text-[17px] mt-4 max-w-xl" data-aos="fade-up" data-aos-delay="100">
        Structuri de traversare proiectate pentru orice tip de obstacol — de la cursuri de apă la căi ferate și artere rutiere.
      </p>
    </div>
  </section>

  <section class="section-padding bg-white">
    <div class="container">
      <div class="grid lg:grid-cols-3 gap-12">
        <!-- Main content -->
        <div class="lg:col-span-2 space-y-8">
          <div data-aos="fade-up">
            <img src="/img/projects/pod.jpg" alt="Proiectare poduri și pasaje" class="w-full rounded-2xl object-cover max-h-72" />
          </div>
          <div data-aos="fade-up">
            <h2 class="text-[26px] font-heading font-bold text-brand-800 mb-4">Proiectare structuri de traversare</h2>
            <p class="text-steel-500 text-[15px] leading-relaxed mb-4">
              ME Design proiectează structuri de traversare pentru orice tip de obstacol — cursuri de apă, căi ferate, artere rutiere sau diferențe de nivel. Fiecare soluție tehnică este adaptată condițiilor specifice de amplasament, volumului de trafic, gabaritelor și condițiilor hidrologice sau geotehnice locale.
            </p>
            <p class="text-steel-500 text-[15px] leading-relaxed mb-4">
              Lucrăm cu autorități locale, consilii județene, beneficiari privați și antreprenori de construcții. Documentațiile pe care le elaborăm respectă normativele tehnice românești (NP, SR, AND) și standardele europene EN aplicabile structurilor de poduri.
            </p>
            <p class="text-steel-500 text-[15px] leading-relaxed">
              Serviciile noastre acoperă toate fazele de proiectare: Studiu de Fezabilitate (SF), Proiect Tehnic (PT) cu memorii tehnice, planuri și calcule de rezistență, Detalii de Execuție (DDE) și asistență tehnică pe șantier.
            </p>
          </div>

          <div data-aos="fade-up">
            <h2 class="text-[22px] font-heading font-bold text-brand-800 mb-4">Tipuri de structuri proiectate</h2>
            <div class="grid sm:grid-cols-2 gap-4">
              {[
                { title: 'Poduri rutiere', desc: 'Poduri din beton armat sau precomprimat pentru drumuri comunale, județene și naționale.' },
                { title: 'Poduri pietonale', desc: 'Traversări pietonale în zone urbane și periurbane, cu design adaptat contextului arhitectural.' },
                { title: 'Pasaje denivelate', desc: 'Structuri de supratraversare sau subtraversare a căilor ferate și arterelor rutiere principale.' },
                { title: 'Pasarele pietonale și cicliste', desc: 'Pasarele ușoare din metal sau beton pentru traversarea cursurilor de apă și infrastructurii existente.' },
                { title: 'Podețe și podeturi', desc: 'Lucrări de artă mici pentru scurgerea apelor de suprafață sub rambleele drumurilor.' },
                { title: 'Consolidări structuri existente', desc: 'Evaluare structurală și proiectare lucrări de consolidare pentru poduri și pasaje existente.' },
              ].map((item) => (
                <div class="bg-steel-50 rounded-2xl p-5 border border-steel-100">
                  <div class="flex items-start gap-3">
                    <svg class="w-5 h-5 text-accent-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    <div>
                      <p class="font-semibold text-brand-800 text-[14px]">{item.title}</p>
                      <p class="text-steel-500 text-[13px] mt-1">{item.desc}</p>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- FAQ -->
          <div data-aos="fade-up">
            <h2 class="text-[22px] font-heading font-bold text-brand-800 mb-4">Întrebări frecvente</h2>
            <div class="space-y-4">
              {[
                {
                  q: 'Ce studii preliminare sunt necesare pentru proiectarea unui pod?',
                  a: 'Sunt necesare: studiu topografic, studiu geotehnic, studiu hidrologic/hidraulic (pentru traversări de cursuri de apă), avize de la administrația bazinală și, după caz, studiu de impact asupra mediului.'
                },
                {
                  q: 'Proiectați și poduri pe drumuri cu finanțare PNRR sau fonduri europene?',
                  a: 'Da, avem experiență cu documentații pentru proiecte co-finanțate din fonduri europene. Asigurăm întreaga documentație tehnică și economică necesară depunerii și implementării proiectelor.'
                },
                {
                  q: 'Care este diferența dintre un pasaj și o pasarelă?',
                  a: 'Un pasaj este o structură care permite traversarea pentru vehicule sau pietoni peste/pe sub o altă cale de comunicație (drum sau cale ferată). O pasarelă este destinată exclusiv traficului pietonal sau ciclistic.'
                },
              ].map((item) => (
                <div class="border border-steel-100 rounded-2xl p-5">
                  <p class="font-semibold text-brand-800 text-[15px] mb-2">{item.q}</p>
                  <p class="text-steel-500 text-[14px] leading-relaxed">{item.a}</p>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-6" data-aos="fade-up">
          <div class="bg-brand-900 rounded-3xl p-6 text-white sticky top-28">
            <h3 class="font-heading font-bold text-[18px] mb-2">Solicită o consultanță gratuită</h3>
            <p class="text-white/60 text-[14px] mb-5">Contactează-ne pentru o evaluare a proiectului tău.</p>
            <a href="/contact" class="block text-center bg-accent-500 hover:bg-accent-600 text-white px-6 py-3 rounded-full font-semibold text-[14px] transition-all">
              Solicită ofertă
            </a>
            <div class="mt-5 pt-5 border-t border-white/10 space-y-3">
              <a href="tel:+40746784156" class="flex items-center gap-3 text-white/70 hover:text-white text-[14px] transition-colors">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                +40 746 784 156
              </a>
              <a href="mailto:office@me-design.ro" class="flex items-center gap-3 text-white/70 hover:text-white text-[14px] transition-colors">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                office@me-design.ro
              </a>
            </div>
          </div>

          <div class="bg-steel-50 rounded-3xl p-6">
            <h3 class="font-heading font-bold text-brand-800 text-[16px] mb-4">Alte servicii</h3>
            <div class="space-y-3">
              <a href="/servicii/proiectare-drumuri" class="flex items-center gap-3 text-steel-600 hover:text-brand-600 text-[14px] transition-colors group">
                <svg class="w-4 h-4 shrink-0 text-brand-400 group-hover:text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                Proiectare drumuri
              </a>
              <a href="/servicii/lucrari-consolidare" class="flex items-center gap-3 text-steel-600 hover:text-brand-600 text-[14px] transition-colors group">
                <svg class="w-4 h-4 shrink-0 text-brand-400 group-hover:text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                Lucrări de sprijin și consolidări
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Schema.org -->
  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Ce studii preliminare sunt necesare pentru proiectarea unui pod?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Sunt necesare: studiu topografic, studiu geotehnic, studiu hidrologic/hidraulic (pentru traversări de cursuri de apă), avize de la administrația bazinală și, după caz, studiu de impact asupra mediului."
        }
      },
      {
        "@type": "Question",
        "name": "Proiectați și poduri pe drumuri cu finanțare PNRR sau fonduri europene?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Da, avem experiență cu documentații pentru proiecte co-finanțate din fonduri europene. Asigurăm întreaga documentație tehnică și economică necesară depunerii și implementării proiectelor."
        }
      },
      {
        "@type": "Question",
        "name": "Care este diferența dintre un pasaj și o pasarelă?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Un pasaj este o structură care permite traversarea pentru vehicule sau pietoni peste/pe sub o altă cale de comunicație (drum sau cale ferată). O pasarelă este destinată exclusiv traficului pietonal sau ciclistic."
        }
      }
    ]
  }
  </script>

  <Footer />
</Layout>
