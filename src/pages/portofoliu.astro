---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Lightbox from '../components/Lightbox.astro';

const projects = [
  {
    title: 'Modernizare drumuri de interes local în Comuna Aninoasa, Județul Dâmbovița',
    category: 'Drumuri',
    faza: 'DALI+DTAC+PTE',
    location: 'U.A.T. Comuna Aninoasa, Județul Dâmbovița',
    year: '2025',
    desc: 'Proiectare pentru modernizarea a 6 străzi locale cu lungimea totală de 2,20 km. Proiectul contribuie la integrarea regiunii în rețeaua europeană de infrastructură, creând premise pentru noi oportunități economice și legături eficiente între centrul urban și zonele periferice.',
  },
  {
    title: 'Realizare Infrastructură Verde – Albastră în Comuna Bughea de Jos, Județul Argeș',
    category: 'Consolidări',
    location: 'U.A.T. Comuna Bughea de Jos, Județul Argeș',
    year: '2025',
    desc: 'Se amenajează albia pârâului Valea Mare pe o lungime de aproximativ 670m, albia pârâului Valea Brezoiului pe o lungime de aproximativ 722m, albia pârâului Valea Caselor pe o lungime de aproximativ 1.250m și albia pârâului Valea Ciocanului pe o lungime de aproximativ 270m.',
  },
];

const categories = ['Toate', ...new Set(projects.map(p => p.category))];
---

<Layout title="Portofoliu" description="Portofoliul ME Design - proiecte de infrastructură finalizate cu succes în toată România.">
  <Header />

  <section class="pt-32 pb-16 bg-gradient-to-br from-brand-900 to-brand-700">
    <div class="container">
      <span class="text-accent-400 font-semibold text-[13px] uppercase tracking-widest" data-aos="fade-up">Portofoliu</span>
      <h1 class="text-[36px] md:text-[52px] font-heading font-extrabold text-white mt-3" data-aos="fade-up" data-aos-delay="50">
        Proiecte realizate
      </h1>
      <p class="text-white/60 text-[17px] mt-4 max-w-xl" data-aos="fade-up" data-aos-delay="100">
        O selecție din proiectele noastre de infrastructură finalizate cu succes.
      </p>
    </div>
  </section>

  <section class="section-padding bg-white">
    <div class="container">
      <div class="flex flex-wrap gap-3 mb-12" data-aos="fade-up">
        {categories.map((cat) => (
          <button class="px-5 py-2 rounded-full text-[14px] font-medium bg-steel-100 text-steel-600 hover:bg-brand-500 hover:text-white transition-all">
            {cat}
          </button>
        ))}
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {projects.map((project, i) => (
          <div class="group glass-card rounded-2xl overflow-hidden hover:shadow-xl transition-all" data-aos="fade-up" data-aos-delay={i * 60}>
            <div class="bg-steel-100 aspect-[16/10] flex items-center justify-center">
              <svg class="w-12 h-12 text-steel-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            <div class="p-6">
              <div class="flex items-center flex-wrap gap-2 mb-3">
                <span class="px-3 py-1 rounded-full bg-brand-500/10 text-brand-500 text-[12px] font-semibold">{project.category}</span>
                {project.faza && <span class="px-3 py-1 rounded-full bg-accent-500/10 text-accent-600 text-[12px] font-semibold">Faza: {project.faza}</span>}
                <span class="text-steel-400 text-[12px]">{project.year}</span>
              </div>
              <h3 class="font-heading font-bold text-[17px] text-brand-800 group-hover:text-accent-500 transition-colors">{project.title}</h3>
              <p class="text-steel-400 text-[13px] mt-1 flex items-center gap-1">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                </svg>
                {project.location}
              </p>
              <p class="text-steel-500 text-[14px] mt-3 leading-relaxed">{project.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Lightbox />
  <Footer />
</Layout>
