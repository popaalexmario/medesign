---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Lightbox from '../components/Lightbox.astro';

const projects = [
  {
    slug: 'aninoasa-dambovita',
    title: 'Modernizare drumuri de interes local în Comuna Aninoasa, Județul Dâmbovița',
    categories: ['Drumuri'],
    faza: 'DALI+DTAC+PTE',
    location: 'U.A.T. Comuna Aninoasa, Județul Dâmbovița',
    year: '2025',
    desc: 'Proiectare pentru modernizarea a 6 străzi locale cu lungimea totală de 2,20 km.',
  },
  {
    slug: 'bughea-de-jos-arges',
    title: 'Realizare Infrastructură Verde – Albastră în Comuna Bughea de Jos, Județul Argeș',
    categories: ['Consolidări', 'Pasarele'],
    faza: 'SF+DTAC+PTE',
    location: 'U.A.T. Comuna Bughea de Jos, Județul Argeș',
    year: '2025',
    desc: 'Proiectare amenajare maluri cu ziduri de sprijin, trotuare si pasarele pentru continuitate circulatie.',
  },
  {
    slug: 'craiova-dolj',
    title: 'Închidere Inel de Trafic Zona de Sud a Municipiului Craiova – Casetare Canal Deschis, Modernizare Str. Râului cu Străpungere DN56 – DN55 Joncțiune cu Aleea 2 Bechet',
    categories: ['Drumuri', 'Consolidări'],
    faza: 'DALI+DTAC+PTE',
    location: 'U.A.T. Municipiul Craiova, Județul Dolj',
    year: '2023 – 2025',
    desc: 'Construirea unei străzi noi în lungime de 2,18 km cu 4 benzi rutiere. Casetarea canalului deschis Craiovița (Râului) pe o lungime de 1.800 ml. Proiectul include 3 sensuri giratorii, piste de biciclete și spații pietonale.',
  },
  {
    slug: 'alba-iulia',
    title: 'Amenajare Sens Giratoriu la Intersecția Străzilor Regiment V Vânători, B-dul. Ferdinand I și DN CALB',
    categories: ['Drumuri'],
    faza: 'DALI',
    location: 'Municipiul Alba Iulia, Județul Alba',
    year: '2024',
    desc: 'Amenajare sens giratoriu pe drum național cu 2 benzi de circulație de 5,50 m.',
  },
  {
    slug: 'pasaj-vacari-maramures',
    title: 'Construire Pasaj „Clubul Văcarilor" (Baia Mare – Recea) DN1C – DN VO BM E58',
    categories: ['Drumuri', 'Poduri'],
    faza: 'SF',
    location: 'U.A.T. Județul Maramureș prin Consiliul Județean Maramureș',
    year: '2023',
    desc: 'Amenajare intersectie DN1C cu DN VO BM si pasaj rutier pe DN1C impreuna cu bretele.',
  },
  {
    slug: 'pasaj-a0-a2-bucuresti',
    title: 'Pasaj pe A0 peste A2 Km 53+069',
    categories: ['Poduri'],
    faza: 'DE',
    location: 'București',
    year: '2020',
    desc: 'Detalii de uzinare si executie pentru pasajul auto pe A0 peste A2 Km 53+069.',
    image: '/img/projects/alarko.jpg',
  },
  {
    slug: 'pasaj-gurasada-hunedoara',
    title: 'Pasaj superior km CF 506+217.83 / km local DN7 0+623.27 — Tronsonul 3: Gurasada–Simeria',
    categories: ['Poduri'],
    faza: 'DE',
    location: 'Comuna Gurasada, Județul Hunedoara',
    year: '2020',
    desc: 'Detalii de uzinare și execuție pentru pasajul auto GZCJ auto, deschidere de 70,00 m.',
    image: '/img/projects/Pasaj%20Gurasada.png',
  },
];

const categoryOrder = ['Drumuri', 'Consolidări', 'Poduri', 'Pasarele'];
const allCats = [...new Set(projects.flatMap(p => p.categories))];
const categories = ['Toate', ...categoryOrder.filter(c => allCats.includes(c)), ...allCats.filter(c => !categoryOrder.includes(c))];
---

<Layout title="Portofoliu" description="Portofoliul ME Design - proiecte reprezentative de infrastructură finalizate cu succes în toată România.">
  <Header />

  <section class="pt-28 pb-8 bg-gradient-to-br from-brand-900 to-brand-700">
    <div class="container">
      <span class="text-accent-400 font-semibold text-[13px] uppercase tracking-widest" data-aos="fade-up">Portofoliu</span>
      <h1 class="text-[36px] md:text-[52px] font-heading font-extrabold text-white mt-3" data-aos="fade-up" data-aos-delay="50">
        Proiecte realizate
      </h1>
      <p class="text-white/60 text-[17px] mt-4 max-w-xl" data-aos="fade-up" data-aos-delay="100">
        O selecție din proiectele noastre de infrastructură finalizate cu succes.
      </p>
    </div>
  </section>

  <section class="py-8 md:py-12 bg-white">
    <div class="container">
      <!-- Search + Filters -->
      <div class="flex flex-col gap-3 mb-6" data-aos="fade-up">
        <div class="relative max-w-md">
          <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-steel-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 111 11a6 6 0 0116 0z" />
          </svg>
          <input
            id="project-search"
            type="text"
            placeholder="Caută proiect, locație..."
            class="w-full pl-10 pr-4 py-2.5 rounded-full border border-steel-200 text-[14px] text-brand-800 placeholder-steel-400 focus:outline-none focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 transition-all"
          />
        </div>
        <div class="flex flex-wrap gap-3" id="filter-buttons">
          {categories.map((cat, i) => (
            <button
              class={`filter-btn px-5 py-2 rounded-full text-[14px] font-medium transition-all ${i === 0 ? 'bg-brand-500 text-white' : 'bg-steel-100 text-steel-600 hover:bg-brand-500 hover:text-white'}`}
              data-cat={cat}
            >
              {cat}
            </button>
          ))}
        </div>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6" id="projects-grid">
        {projects.map((project, i) => (
          <div
            id={project.slug}
            class="group glass-card rounded-2xl overflow-hidden hover:shadow-xl transition-all project-card"
            data-aos="fade-up"
            data-aos-delay={i * 60}
            data-categories={project.categories.join(',')}
            data-search={`${project.title} ${project.location} ${project.desc}`.toLowerCase()}
          >
            <div class="bg-steel-100 aspect-[16/10] overflow-hidden flex items-center justify-center">
              {project.image
                ? <img src={project.image} alt={project.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                : <svg class="w-12 h-12 text-steel-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
              }
            </div>
            <div class="p-4">
              <div class="flex items-center flex-wrap gap-2 mb-3">
                {project.categories.map((cat) => (
                  <span class="px-3 py-1 rounded-full bg-brand-500/10 text-brand-500 text-[12px] font-semibold">{cat}</span>
                ))}
                {project.faza && <span class="px-3 py-1 rounded-full bg-accent-500/10 text-accent-600 text-[12px] font-semibold">Faza: {project.faza}</span>}
                <span class="text-steel-400 text-[12px]">{project.year}</span>
              </div>
              <h3 class="font-heading font-bold text-[17px] text-brand-800 group-hover:text-accent-500 transition-colors">{project.title}</h3>
              <p class="text-steel-400 text-[13px] mt-1 flex items-center gap-1">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                </svg>
                {project.location}
              </p>
              <p class="text-steel-500 text-[14px] mt-3 leading-relaxed">{project.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <p id="no-results" class="hidden text-center text-steel-400 text-[15px] py-16">Niciun proiect găsit. Încearcă alt termen de căutare.</p>
    </div>
  </section>

  <script>
    const searchInput = document.getElementById('project-search') as HTMLInputElement;
    const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const cards = document.querySelectorAll<HTMLElement>('.project-card');
    const noResults = document.getElementById('no-results')!;

    let activeCategory = 'Toate';
    let searchQuery = '';

    function applyFilters() {
      let visible = 0;
      cards.forEach(card => {
        const cats = card.dataset.categories ?? '';
        const searchText = card.dataset.search ?? '';
        const catMatch = activeCategory === 'Toate' || cats.split(',').includes(activeCategory);
        const searchMatch = searchQuery === '' || searchText.includes(searchQuery);
        const show = catMatch && searchMatch;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      noResults.classList.toggle('hidden', visible > 0);
    }

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        activeCategory = btn.dataset.cat ?? 'Toate';
        filterBtns.forEach(b => {
          b.classList.toggle('bg-brand-500', b === btn);
          b.classList.toggle('text-white', b === btn);
          b.classList.toggle('bg-steel-100', b !== btn);
          b.classList.toggle('text-steel-600', b !== btn);
        });
        applyFilters();
      });
    });

    searchInput.addEventListener('input', () => {
      searchQuery = searchInput.value.toLowerCase().trim();
      applyFilters();
    });

    // Scroll to & highlight project from map anchor
    const hash = window.location.hash.slice(1);
    if (hash) {
      const target = document.getElementById(hash);
      if (target) {
        setTimeout(() => {
          target.scrollIntoView({ behavior: 'smooth', block: 'center' });
          target.style.outline = '3px solid #d97706';
          target.style.outlineOffset = '4px';
          target.style.borderRadius = '1rem';
          setTimeout(() => { target.style.outline = ''; target.style.outlineOffset = ''; }, 2500);
        }, 400);
      }
    }
  </script>

  <Lightbox />
  <Footer />
</Layout>
