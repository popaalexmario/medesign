---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const stats = [
  { value: 15, suffix: '+', label: 'Ani experiență', icon: '📐' },
  { value: 200, suffix: '+', label: 'Proiecte finalizate', icon: '🏗️' },
  { value: 50, suffix: '+', label: 'Km drumuri proiectate', icon: '🛣️' },
  { value: 100, suffix: '%', label: 'Proiecte la termen', icon: '✅' },
];

const services = [
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l5.447 2.724A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" /></svg>`,
    title: 'Proiectare drumuri',
    desc: 'Proiectare completă drumuri comunale, județene și naționale. De la studiu topografic la detalii de execuție.',
    href: '/servicii/proiectare-drumuri',
    color: 'from-blue-500 to-blue-700',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>`,
    title: 'Rețele edilitare',
    desc: 'Proiectare rețele de apă, canalizare, gaze naturale și alimentare cu energie electrică.',
    href: '/servicii/retele-edilitare',
    color: 'from-emerald-500 to-emerald-700',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>`,
    title: 'Studii de fezabilitate',
    desc: 'Analize tehnico-economice complete, documentații pentru finanțări europene și guvernamentale.',
    href: '/servicii/studii-fezabilitate',
    color: 'from-amber-500 to-amber-700',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>`,
    title: 'Asistență tehnică',
    desc: 'Supraveghere și asistență tehnică pe toată durata execuției lucrărilor de infrastructură.',
    href: '/servicii/asistenta-tehnica',
    color: 'from-violet-500 to-violet-700',
  },
];

const process = [
  { step: '01', title: 'Analiză', desc: 'Evaluăm cerințele proiectului, studiem amplasamentul și identificăm soluțiile optime.', icon: '🔍' },
  { step: '02', title: 'Proiectare', desc: 'Elaborăm documentația tehnică completă cu respectarea tuturor normativelor în vigoare.', icon: '📐' },
  { step: '03', title: 'Avizare', desc: 'Obținem toate avizele și acordurile necesare de la autoritățile competente.', icon: '📋' },
  { step: '04', title: 'Livrare', desc: 'Predăm proiectul finalizat și oferim suport pe toată durata implementării.', icon: '🚀' },
];

const reasons = [
  { icon: '🏗️', title: 'Experiență dovedită', desc: 'Peste 15 ani în proiectarea infrastructurii, cu sute de proiecte livrate cu succes.' },
  { icon: '📋', title: 'Documentație completă', desc: 'Proiecte tehnice conforme cu legislația în vigoare, gata pentru autorizare și licitații.' },
  { icon: '⏱️', title: 'Respectăm termenele', desc: 'Livrare la termen, fără surprize. Planificare riguroasă și comunicare constantă.' },
  { icon: '🤝', title: 'Partener de încredere', desc: 'Colaborăm strâns cu autoritățile locale, constructorii și beneficiarii finali.' },
];
---

<Layout title="Proiectare Infrastructură">
  <Header />

  <!-- HERO with animated blueprint -->
  <section class="relative min-h-screen flex items-center overflow-hidden bg-gradient-to-br from-brand-900 via-brand-700 to-brand-500">
    <!-- Animated background elements -->
    <div class="absolute inset-0">
      <!-- Morphing blobs -->
      <div class="absolute top-20 right-10 w-[500px] h-[500px] bg-accent-500/8 animate-morph" style="animation-delay: 0s"></div>
      <div class="absolute bottom-20 left-10 w-[400px] h-[400px] bg-brand-300/10 animate-morph" style="animation-delay: -4s"></div>
      <div class="absolute top-1/2 right-1/3 w-[300px] h-[300px] bg-blue-400/5 animate-morph" style="animation-delay: -2s"></div>

      <!-- Animated blueprint SVG -->
      <svg class="absolute inset-0 w-full h-full" xmlns="http://www.w3.org/2000/svg">
        <!-- Grid lines that draw in -->
        <defs>
          <pattern id="blueprint-grid" width="60" height="60" patternUnits="userSpaceOnUse">
            <path d="M 60 0 L 0 0 0 60" fill="none" stroke="rgba(255,255,255,0.06)" stroke-width="0.5"
              stroke-dasharray="1000" class="animate-draw-path" style="stroke-dashoffset: 1000" />
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#blueprint-grid)" />

        <!-- Animated road path -->
        <path d="M-50,600 Q200,550 400,480 T800,350 T1200,280 T1600,200"
          fill="none" stroke="rgba(217,119,6,0.15)" stroke-width="3"
          stroke-dasharray="2000" stroke-dashoffset="2000"
          class="animate-draw-path" style="animation-delay: 0.5s; animation-duration: 3s" />

        <!-- Secondary road -->
        <path d="M-50,700 Q300,650 500,600 T900,500 T1400,380"
          fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="2"
          stroke-dasharray="2000" stroke-dashoffset="2000"
          class="animate-draw-path" style="animation-delay: 1s; animation-duration: 3s" />

        <!-- Intersection circle -->
        <circle cx="50%" cy="55%" r="40" fill="none" stroke="rgba(217,119,6,0.12)" stroke-width="1.5"
          stroke-dasharray="260" stroke-dashoffset="260"
          class="animate-draw-path" style="animation-delay: 2s; animation-duration: 1.5s" />

        <!-- Measurement markers -->
        <line x1="20%" y1="75%" x2="50%" y2="75%" stroke="rgba(255,255,255,0.08)" stroke-width="1"
          stroke-dasharray="500" stroke-dashoffset="500"
          class="animate-draw-path" style="animation-delay: 1.5s; animation-duration: 2s" />
        <line x1="20%" y1="73%" x2="20%" y2="77%" stroke="rgba(255,255,255,0.1)" stroke-width="1" />
        <line x1="50%" y1="73%" x2="50%" y2="77%" stroke="rgba(255,255,255,0.1)" stroke-width="1" />
      </svg>

      <!-- Floating geometric shapes -->
      <div class="absolute top-32 right-[15%] w-16 h-16 border border-white/10 rounded-lg animate-float-slow" style="animation-delay: 0s"></div>
      <div class="absolute top-[45%] right-[8%] w-8 h-8 bg-accent-500/20 rounded-full animate-float-slow" style="animation-delay: -2s"></div>
      <div class="absolute bottom-32 right-[25%] w-12 h-12 border border-accent-500/15 animate-rotate-slow"></div>
      <div class="absolute top-[60%] left-[5%] w-20 h-20 border border-white/5 rounded-2xl animate-float-slow" style="animation-delay: -4s"></div>
    </div>

    <div class="container relative z-10 pt-32 pb-20">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 backdrop-blur-sm border border-white/10 text-white/70 text-[13px] font-medium mb-8" data-aos="fade-down">
            <span class="w-2 h-2 bg-accent-400 rounded-full animate-pulse"></span>
            Proiectare profesională de infrastructură
          </div>

          <h1 class="text-[40px] md:text-[56px] lg:text-[68px] font-heading font-extrabold text-white leading-[1.05] mb-6" data-aos="fade-up">
            Construim
            <span class="relative inline-block">
              <span class="text-accent-400">fundația</span>
              <svg class="absolute -bottom-2 left-0 w-full" viewBox="0 0 200 12" fill="none">
                <path d="M2 10C50 2 150 2 198 10" stroke="#d97706" stroke-width="3" stroke-linecap="round"
                  stroke-dasharray="200" stroke-dashoffset="200"
                  class="animate-draw-path" style="animation-delay: 1s; animation-duration: 1.5s" />
              </svg>
            </span>
            <br />infrastructurii
            <br />de mâine
          </h1>

          <p class="text-white/60 text-[17px] md:text-[19px] max-w-xl leading-relaxed mb-10" data-aos="fade-up" data-aos-delay="100">
            Servicii integrate de proiectare drumuri, rețele edilitare, studii de fezabilitate și asistență tehnică. Experiență, precizie, rezultate.
          </p>

          <div class="flex flex-col sm:flex-row gap-4" data-aos="fade-up" data-aos-delay="200">
            <a href="/contact" class="group inline-flex items-center justify-center gap-2 bg-accent-500 text-white px-8 py-4 rounded-full font-semibold text-[15px] hover:bg-accent-600 transition-all hover:shadow-lg hover:shadow-accent-500/25 relative overflow-hidden">
              <span class="relative z-10">Solicită ofertă</span>
              <svg class="w-4 h-4 relative z-10 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
              <div class="absolute inset-0 animate-shimmer"></div>
            </a>
            <a href="/portofoliu" class="inline-flex items-center justify-center gap-2 bg-white/10 backdrop-blur-sm text-white px-8 py-4 rounded-full font-semibold text-[15px] border border-white/20 hover:bg-white/20 transition-all">
              Vezi portofoliu
            </a>
          </div>
        </div>

        <!-- Hero mockup - Road Design Animation -->
        <div class="hidden lg:block" data-aos="fade-left" data-aos-delay="300">
          <div class="relative">
            <div class="bg-white/5 backdrop-blur-md border border-white/10 rounded-3xl p-6 animate-float-slow">
              <!-- Window chrome -->
              <div class="flex items-center gap-3 mb-5">
                <div class="w-3 h-3 rounded-full bg-red-400/60"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-400/60"></div>
                <div class="w-3 h-3 rounded-full bg-green-400/60"></div>
                <span class="ml-2 text-white/30 text-[12px] font-mono">proiect_drum_DJ107.dwg</span>
              </div>

              <!-- PLAN VIEW - Top down road with roundabout -->
              <div class="mb-4">
                <div class="flex items-center gap-2 mb-2">
                  <div class="w-1.5 h-1.5 bg-cyan-400/60 rounded-full"></div>
                  <span class="text-white/25 text-[10px] font-mono uppercase tracking-wider">Plan de situație — 1:500</span>
                </div>
                <svg viewBox="0 0 420 160" class="w-full" xmlns="http://www.w3.org/2000/svg" id="plan-view">
                  <!-- Road body -->
                  <path d="M0,90 L130,90 Q155,90 165,70 Q175,50 200,50 Q225,50 235,70 Q245,90 270,90 L420,90"
                    fill="none" stroke="rgba(217,119,6,0.5)" stroke-width="28" stroke-linecap="round"
                    class="road-layer" style="--delay: 1.2s" />
                  <!-- Road edges -->
                  <path d="M0,76 L125,76 Q152,76 163,58 Q174,40 200,40 Q226,40 237,58 Q248,76 275,76 L420,76"
                    fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1"
                    class="road-layer" style="--delay: 1.8s" />
                  <path d="M0,104 L125,104 Q152,104 163,86 Q174,60 200,60 Q226,60 237,82 Q248,104 275,104 L420,104"
                    fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1"
                    class="road-layer" style="--delay: 1.8s" />
                  <!-- Center dashed line -->
                  <path d="M0,90 L130,90 Q155,90 165,70 Q175,50 200,50 Q225,50 235,70 Q245,90 270,90 L420,90"
                    fill="none" stroke="rgba(255,255,255,0.3)" stroke-width="1" stroke-dasharray="8,8"
                    class="road-layer" style="--delay: 2.2s" />

                  <!-- Roundabout -->
                  <circle cx="200" cy="50" r="22" fill="none" stroke="rgba(217,119,6,0.6)" stroke-width="2"
                    class="road-layer" style="--delay: 2.6s" />
                  <circle cx="200" cy="50" r="8" fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="1"
                    class="road-layer" style="--delay: 2.9s" />
                  <!-- Roundabout arrows -->
                  <path d="M185,30 Q200,25 215,30" fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="0.8"
                    marker-end="url(#arrowhead)"
                    class="road-layer" style="--delay: 3.1s" />

                  <!-- Side road into roundabout -->
                  <path d="M200,10 L200,28" fill="none" stroke="rgba(217,119,6,0.35)" stroke-width="14"
                    class="road-layer" style="--delay: 3s" />
                  <path d="M200,10 L200,28" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="0.8" stroke-dasharray="4,4"
                    class="road-layer" style="--delay: 3.3s" />

                  <!-- Dimension lines -->
                  <line x1="0" y1="130" x2="130" y2="130" stroke="rgba(100,200,255,0.25)" stroke-width="0.5"
                    class="road-layer" style="--delay: 3.5s" />
                  <line x1="0" y1="127" x2="0" y2="133" stroke="rgba(100,200,255,0.25)" stroke-width="0.5"
                    class="road-layer" style="--delay: 3.5s" />
                  <line x1="130" y1="127" x2="130" y2="133" stroke="rgba(100,200,255,0.25)" stroke-width="0.5"
                    class="road-layer" style="--delay: 3.5s" />
                  <text x="65" y="143" fill="rgba(100,200,255,0.3)" font-size="7" text-anchor="middle" font-family="monospace"
                    class="road-text" style="--delay: 3.7s">260m</text>

                  <line x1="270" y1="130" x2="420" y2="130" stroke="rgba(100,200,255,0.25)" stroke-width="0.5"
                    class="road-layer" style="--delay: 3.6s" />
                  <line x1="270" y1="127" x2="270" y2="133" stroke="rgba(100,200,255,0.25)" stroke-width="0.5"
                    class="road-layer" style="--delay: 3.6s" />
                  <line x1="420" y1="127" x2="420" y2="133" stroke="rgba(100,200,255,0.25)" stroke-width="0.5"
                    class="road-layer" style="--delay: 3.6s" />
                  <text x="345" y="143" fill="rgba(100,200,255,0.3)" font-size="7" text-anchor="middle" font-family="monospace"
                    class="road-text" style="--delay: 3.8s">300m</text>

                  <!-- Radius annotation on curve -->
                  <path d="M170,35 Q185,25 195,30" fill="none" stroke="rgba(100,200,255,0.2)" stroke-width="0.5"
                    class="road-layer" style="--delay: 3.9s" />
                  <text x="168" y="30" fill="rgba(100,200,255,0.3)" font-size="6" text-anchor="end" font-family="monospace"
                    class="road-text" style="--delay: 4s">R=22m</text>

                  <!-- Buildings (parcels) -->
                  <rect x="30" y="115" width="18" height="12" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="0.5" stroke-dasharray="2,2"
                    class="road-layer" style="--delay: 4.1s" />
                  <rect x="60" y="112" width="22" height="14" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="0.5" stroke-dasharray="2,2"
                    class="road-layer" style="--delay: 4.2s" />
                  <rect x="320" y="112" width="25" height="12" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="0.5" stroke-dasharray="2,2"
                    class="road-layer" style="--delay: 4.3s" />
                  <rect x="360" y="110" width="20" height="16" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="0.5" stroke-dasharray="2,2"
                    class="road-layer" style="--delay: 4.4s" />

                  <defs>
                    <marker id="arrowhead" markerWidth="6" markerHeight="4" refX="5" refY="2" orient="auto">
                      <path d="M0,0 L6,2 L0,4" fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="0.5" />
                    </marker>
                  </defs>
                </svg>
              </div>

              <!-- Separator line -->
              <div class="border-t border-white/10 my-4"></div>

              <!-- CROSS SECTION - Layer by layer -->
              <div>
                <div class="flex items-center gap-2 mb-2">
                  <div class="w-1.5 h-1.5 bg-accent-400/60 rounded-full"></div>
                  <span class="text-white/25 text-[10px] font-mono uppercase tracking-wider">Profil transversal tip — 1:50</span>
                </div>
                <svg viewBox="0 0 420 150" class="w-full" xmlns="http://www.w3.org/2000/svg" id="cross-section">
                  <!-- Natural terrain -->
                  <path d="M0,120 Q50,118 100,115 Q150,110 210,108 Q270,110 320,115 Q370,118 420,120 L420,150 L0,150 Z"
                    fill="rgba(120,80,40,0.15)" stroke="rgba(120,80,40,0.3)" stroke-width="0.8"
                    class="layer-reveal" style="--delay: 1.5s" />
                  <text x="380" y="138" fill="rgba(120,80,40,0.3)" font-size="5.5" font-family="monospace"
                    class="road-text" style="--delay: 1.8s">Teren natural</text>

                  <!-- Excavation shape -->
                  <path d="M80,115 L100,105 L120,95 L140,88 L160,84 L190,82 L220,82 L250,82 L270,84 L290,88 L310,95 L330,105 L340,115"
                    fill="rgba(90,60,30,0.2)" stroke="rgba(150,100,50,0.3)" stroke-width="0.8"
                    class="layer-reveal" style="--delay: 2.2s" />

                  <!-- Subbase - pietris -->
                  <path d="M110,105 L130,95 L150,88 L180,85 L210,83 L240,85 L270,88 L290,95 L310,105 L310,108 L290,100 L270,93 L240,90 L210,88 L180,90 L150,93 L130,100 L110,108 Z"
                    fill="rgba(180,160,120,0.25)" stroke="rgba(180,160,120,0.4)" stroke-width="0.8"
                    class="layer-reveal" style="--delay: 2.8s" />
                  <text x="355" y="105" fill="rgba(180,160,120,0.4)" font-size="5.5" font-family="monospace"
                    class="road-text" style="--delay: 3s">Fundație (20cm)</text>

                  <!-- Base course - balast stabilizat -->
                  <path d="M130,95 L155,88 L185,84 L210,82 L235,84 L265,88 L290,95 L290,99 L265,92 L235,88 L210,86 L185,88 L155,92 L130,99 Z"
                    fill="rgba(160,170,180,0.3)" stroke="rgba(160,170,180,0.45)" stroke-width="0.8"
                    class="layer-reveal" style="--delay: 3.4s" />
                  <text x="355" y="95" fill="rgba(160,170,180,0.45)" font-size="5.5" font-family="monospace"
                    class="road-text" style="--delay: 3.6s">Bază (15cm)</text>

                  <!-- Binder layer -->
                  <path d="M145,88 L170,83 L195,80 L210,79 L225,80 L250,83 L275,88 L275,91 L250,86 L225,83 L210,82 L195,83 L170,86 L145,91 Z"
                    fill="rgba(80,80,80,0.35)" stroke="rgba(100,100,100,0.5)" stroke-width="0.8"
                    class="layer-reveal" style="--delay: 4s" />
                  <text x="355" y="87" fill="rgba(100,100,100,0.5)" font-size="5.5" font-family="monospace"
                    class="road-text" style="--delay: 4.2s">Binder (6cm)</text>

                  <!-- Wearing course - asfalt -->
                  <path d="M150,86 L175,82 L200,79 L210,78 L220,79 L245,82 L270,86 L270,88 L245,84 L220,81 L210,80 L200,81 L175,84 L150,88 Z"
                    fill="rgba(50,50,50,0.5)" stroke="rgba(217,119,6,0.6)" stroke-width="1"
                    class="layer-reveal" style="--delay: 4.6s" />
                  <text x="355" y="80" fill="rgba(217,119,6,0.5)" font-size="5.5" font-family="monospace"
                    class="road-text" style="--delay: 4.8s">Uzură (4cm)</text>

                  <!-- Road markings on top -->
                  <line x1="207" y1="78" x2="213" y2="78" stroke="rgba(255,255,255,0.6)" stroke-width="1.5"
                    class="layer-reveal" style="--delay: 5.2s" />
                  <line x1="160" y1="86" x2="163" y2="86" stroke="rgba(255,255,255,0.4)" stroke-width="1"
                    class="layer-reveal" style="--delay: 5.3s" />
                  <line x1="257" y1="86" x2="260" y2="86" stroke="rgba(255,255,255,0.4)" stroke-width="1"
                    class="layer-reveal" style="--delay: 5.3s" />

                  <!-- Curbs -->
                  <rect x="148" y="83" width="4" height="6" fill="rgba(200,200,200,0.3)" stroke="rgba(200,200,200,0.4)" stroke-width="0.5"
                    class="layer-reveal" style="--delay: 5.4s" />
                  <rect x="268" y="83" width="4" height="6" fill="rgba(200,200,200,0.3)" stroke="rgba(200,200,200,0.4)" stroke-width="0.5"
                    class="layer-reveal" style="--delay: 5.4s" />
                  <text x="140" y="78" fill="rgba(200,200,200,0.3)" font-size="5" font-family="monospace" text-anchor="end"
                    class="road-text" style="--delay: 5.5s">bordură</text>
                  <text x="280" y="78" fill="rgba(200,200,200,0.3)" font-size="5" font-family="monospace"
                    class="road-text" style="--delay: 5.5s">bordură</text>

                  <!-- Sidewalk -->
                  <path d="M115,105 L145,88 L148,88 L148,90 L118,108 Z"
                    fill="rgba(200,180,150,0.15)" stroke="rgba(200,180,150,0.25)" stroke-width="0.5"
                    class="layer-reveal" style="--delay: 5.6s" />
                  <path d="M272,88 L305,105 L302,108 L272,90 Z"
                    fill="rgba(200,180,150,0.15)" stroke="rgba(200,180,150,0.25)" stroke-width="0.5"
