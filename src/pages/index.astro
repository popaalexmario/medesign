---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const stats = [
  { value: 15, suffix: '+', label: 'Ani experiență', icon: '📐' },
  { value: 200, suffix: '+', label: 'Proiecte finalizate', icon: '🏗️' },
  { value: 50, suffix: '+', label: 'Km drumuri proiectate', icon: '🛣️' },
  { value: 100, suffix: '%', label: 'Proiecte la termen', icon: '✅' },
];

const services = [
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l5.447 2.724A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" /></svg>`,
    title: 'Proiectare drumuri',
    desc: 'Proiectare completă drumuri comunale, județene și naționale. De la studiu topografic la detalii de execuție.',
    href: '/servicii/proiectare-drumuri',
    color: 'from-blue-500 to-blue-700',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>`,
    title: 'Rețele edilitare',
    desc: 'Proiectare rețele de apă, canalizare, gaze naturale și alimentare cu energie electrică.',
    href: '/servicii/retele-edilitare',
    color: 'from-emerald-500 to-emerald-700',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>`,
    title: 'Studii de fezabilitate',
    desc: 'Analize tehnico-economice complete, documentații pentru finanțări europene și guvernamentale.',
    href: '/servicii/studii-fezabilitate',
    color: 'from-amber-500 to-amber-700',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>`,
    title: 'Asistență tehnică',
    desc: 'Supraveghere și asistență tehnică pe toată durata execuției lucrărilor de infrastructură.',
    href: '/servicii/asistenta-tehnica',
    color: 'from-violet-500 to-violet-700',
  },
];

const process = [
  { step: '01', title: 'Analiză', desc: 'Evaluăm cerințele proiectului, studiem amplasamentul și identificăm soluțiile optime.', icon: '🔍' },
  { step: '02', title: 'Proiectare', desc: 'Elaborăm documentația tehnică completă cu respectarea tuturor normativelor în vigoare.', icon: '📐' },
  { step: '03', title: 'Avizare', desc: 'Obținem toate avizele și acordurile necesare de la autoritățile competente.', icon: '📋' },
  { step: '04', title: 'Livrare', desc: 'Predăm proiectul finalizat și oferim suport pe toată durata implementării.', icon: '🚀' },
];

const reasons = [
  { icon: '🏗️', title: 'Experiență dovedită', desc: 'Peste 15 ani în proiectarea infrastructurii, cu sute de proiecte livrate cu succes.' },
  { icon: '📋', title: 'Documentație completă', desc: 'Proiecte tehnice conforme cu legislația în vigoare, gata pentru autorizare și licitații.' },
  { icon: '⏱️', title: 'Respectăm termenele', desc: 'Livrare la termen, fără surprize. Planificare riguroasă și comunicare constantă.' },
  { icon: '🤝', title: 'Partener de încredere', desc: 'Colaborăm strâns cu autoritățile locale, constructorii și beneficiarii finali.' },
];
---

<Layout title="Proiectare Infrastructură">
  <Header />

  <!-- HERO - Fullscreen road canvas -->
  <section class="relative min-h-screen flex items-center overflow-hidden">
    <!-- Canvas background - road being built -->
    <canvas id="road-canvas" class="absolute inset-0 w-full h-full"></canvas>

    <!-- Dark overlay for text readability -->
    <div class="absolute inset-0 bg-gradient-to-r from-brand-900/95 via-brand-900/80 to-brand-900/40"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-brand-900/90 via-transparent to-brand-900/60"></div>

    <div class="container relative z-10 pt-32 pb-20">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/10 backdrop-blur-sm border border-white/10 text-white/70 text-[13px] font-medium mb-8" data-aos="fade-down">
          <span class="w-2 h-2 bg-accent-400 rounded-full animate-pulse"></span>
          Proiectare profesională de infrastructură
        </div>

        <h1 class="text-[42px] md:text-[60px] lg:text-[76px] font-heading font-extrabold text-white leading-[1.05] mb-6" data-aos="fade-up">
          Construim
          <span class="relative inline-block">
            <span class="text-accent-400">fundația</span>
            <svg class="absolute -bottom-2 left-0 w-full" viewBox="0 0 200 12" fill="none">
              <path d="M2 10C50 2 150 2 198 10" stroke="#d97706" stroke-width="3" stroke-linecap="round"
                stroke-dasharray="200" stroke-dashoffset="200"
                class="animate-draw-path" style="animation-delay: 1s; animation-duration: 1.5s" />
            </svg>
          </span>
          <br />infrastructurii
          <br />de mâine
        </h1>

        <p class="text-white/60 text-[18px] md:text-[20px] max-w-xl leading-relaxed mb-10" data-aos="fade-up" data-aos-delay="100">
          Servicii integrate de proiectare drumuri, rețele edilitare, studii de fezabilitate și asistență tehnică. Experiență, precizie, rezultate.
        </p>

        <div class="flex flex-col sm:flex-row gap-4" data-aos="fade-up" data-aos-delay="200">
          <a href="/contact" class="group inline-flex items-center justify-center gap-2 bg-accent-500 text-white px-8 py-4 rounded-full font-semibold text-[15px] hover:bg-accent-600 transition-all hover:shadow-lg hover:shadow-accent-500/25 relative overflow-hidden">
            <span class="relative z-10">Solicită ofertă</span>
            <svg class="w-4 h-4 relative z-10 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
            <div class="absolute inset-0 animate-shimmer"></div>
          </a>
          <a href="/portofoliu" class="inline-flex items-center justify-center gap-2 bg-white/10 backdrop-blur-sm text-white px-8 py-4 rounded-full font-semibold text-[15px] border border-white/20 hover:bg-white/20 transition-all">
            Vezi portofoliu
          </a>
        </div>
      </div>

      <!-- Stats with counter animation -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-20">
        {stats.map((stat, i) => (
          <div class="group bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-6 text-center hover:bg-white/10 hover:border-white/20 transition-all duration-500 cursor-default"
            data-aos="fade-up" data-aos-delay={150 + i * 100}>
            <span class="text-[24px] block mb-2">{stat.icon}</span>
            <div class="text-[32px] md:text-[40px] font-heading font-extrabold text-white counter-glow">
              <span class="counter" data-target={stat.value} data-suffix={stat.suffix}>0{stat.suffix}</span>
            </div>
            <div class="text-white/40 text-[13px] font-medium mt-1 group-hover:text-white/60 transition-colors">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICII with 3D tilt cards -->
  <section class="section-padding bg-steel-50 relative overflow-hidden" id="servicii">
    <!-- Background decoration -->
    <div class="absolute top-0 right-0 w-[400px] h-[400px] bg-brand-500/3 rounded-full blur-[100px]"></div>
    <div class="absolute bottom-0 left-0 w-[300px] h-[300px] bg-accent-500/3 rounded-full blur-[80px]"></div>

    <div class="container relative z-10">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="text-accent-500 font-semibold text-[13px] uppercase tracking-widest" data-aos="fade-up">Ce facem</span>
        <h2 class="text-[32px] md:text-[44px] font-heading font-bold text-brand-800 mt-3" data-aos="fade-up" data-aos-delay="50">
          Servicii de proiectare
        </h2>
        <p class="text-steel-500 text-[16px] mt-4 leading-relaxed" data-aos="fade-up" data-aos-delay="100">
          Oferim soluții complete de proiectare infrastructură, de la concept la implementare.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {services.map((service, i) => (
          <a href={service.href} class="group tilt-card glass-card rounded-2xl p-8 relative overflow-hidden" data-aos="fade-up" data-aos-delay={i * 100}>
            <div class={`absolute top-0 right-0 w-32 h-32 bg-gradient-to-br ${service.color} opacity-0 group-hover:opacity-10 rounded-full blur-[40px] transition-opacity duration-500 -translate-y-8 translate-x-8`}></div>
            <div class="tilt-inner relative z-10">
              <div class="w-14 h-14 bg-brand-500/10 rounded-xl flex items-center justify-center text-brand-500 group-hover:bg-accent-500 group-hover:text-white transition-all duration-300 group-hover:scale-110 group-hover:rotate-3" set:html={service.icon} />
              <h3 class="font-heading font-bold text-[20px] text-brand-800 mt-5 group-hover:text-accent-500 transition-colors">{service.title}</h3>
              <p class="text-steel-500 text-[15px] mt-3 leading-relaxed">{service.desc}</p>
              <div class="flex items-center gap-1 text-accent-500 font-semibold text-[14px] mt-5 translate-x-0 group-hover:translate-x-2 transition-transform">
                Detalii
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCES with animated timeline -->
  <section class="section-padding bg-white relative overflow-hidden">
    <div class="container">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="text-accent-500 font-semibold text-[13px] uppercase tracking-widest" data-aos="fade-up">Cum lucrăm</span>
        <h2 class="text-[32px] md:text-[44px] font-heading font-bold text-brand-800 mt-3" data-aos="fade-up" data-aos-delay="50">
          Proces transparent, rezultate predictibile
        </h2>
      </div>

      <!-- Timeline desktop -->
      <div class="hidden md:block relative mb-8">
        <div class="absolute top-12 left-[12%] right-[12%] h-0.5 bg-steel-100 rounded-full overflow-hidden">
          <div class="h-full bg-gradient-to-r from-accent-500 via-brand-500 to-accent-500 rounded-full timeline-progress" style="width: 0%"></div>
        </div>
      </div>

      <div class="grid md:grid-cols-4 gap-8">
        {process.map((item, i) => (
          <div class="relative process-step" data-aos="fade-up" data-aos-delay={i * 150}>
            <div class="text-center md:text-left">
              <div class="relative inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-gradient-to-br from-brand-500/10 to-accent-500/10 border border-brand-500/10 mb-5 group-hover:scale-110 transition-transform mx-auto md:mx-0">
                <span class="text-[28px]">{item.icon}</span>
                <span class="absolute -top-2 -right-2 w-7 h-7 rounded-lg bg-accent-500 text-white text-[11px] font-bold flex items-center justify-center shadow-lg shadow-accent-500/30">{item.step}</span>
              </div>
              <h3 class="font-heading font-bold text-[18px] text-brand-800">{item.title}</h3>
              <p class="text-steel-500 text-[14px] mt-3 leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- DE CE NOI with hover animations -->
  <section class="section-padding bg-brand-900 text-white relative overflow-hidden">
    <!-- Parallax floating elements -->
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute top-20 left-[10%] w-2 h-2 bg-accent-400/20 rounded-full parallax-layer" data-speed="2"></div>
      <div class="absolute top-40 right-[15%] w-3 h-3 bg-white/5 rounded-full parallax-layer" data-speed="3"></div>
      <div class="absolute bottom-32 left-[20%] w-4 h-4 bg-accent-400/10 rounded-full parallax-layer" data-speed="1.5"></div>
      <div class="absolute top-[60%] right-[30%] w-1.5 h-1.5 bg-white/10 rounded-full parallax-layer" data-speed="4"></div>
      <div class="absolute top-[30%] left-[40%] w-24 h-24 border border-white/[0.03] rounded-full animate-rotate-slow"></div>
      <div class="absolute bottom-[20%] right-[10%] w-32 h-32 border border-white/[0.02] rounded-2xl animate-rotate-slow" style="animation-direction: reverse; animation-duration: 45s"></div>
    </div>

    <div class="container relative z-10">
      <div class="text-center max-w-2xl mx-auto mb-16">
        <span class="text-accent-400 font-semibold text-[13px] uppercase tracking-widest" data-aos="fade-up">De ce noi</span>
        <h2 class="text-[32px] md:text-[44px] font-heading font-bold text-white mt-3" data-aos="fade-up" data-aos-delay="50">
          Partenerul potrivit pentru proiectul tău
        </h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {reasons.map((item, i) => (
          <div class="group bg-white/5 border border-white/10 rounded-2xl p-7 hover:bg-white/10 hover:border-accent-500/30 transition-all duration-500 hover:-translate-y-2" data-aos="fade-up" data-aos-delay={i * 100}>
            <span class="text-[36px] block group-hover:scale-125 transition-transform duration-300">{item.icon}</span>
            <h3 class="font-heading font-bold text-[17px] text-white mt-4">{item.title}</h3>
            <p class="text-white/50 text-[14px] mt-3 leading-relaxed group-hover:text-white/70 transition-colors">{item.desc}</p>
            <div class="mt-4 h-0.5 bg-white/5 rounded-full overflow-hidden">
              <div class="h-full w-0 group-hover:w-full bg-gradient-to-r from-accent-500 to-brand-300 transition-all duration-700 rounded-full"></div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA with animated gradient -->
  <section class="section-padding bg-steel-50">
    <div class="container">
      <div class="relative bg-gradient-to-br from-brand-500 to-brand-700 rounded-3xl p-12 md:p-16 text-center overflow-hidden" data-aos="fade-up">
        <div class="absolute top-0 right-0 w-[300px] h-[300px] bg-accent-500/20 rounded-full blur-[80px] animate-morph"></div>
        <div class="absolute bottom-0 left-0 w-[200px] h-[200px] bg-brand-300/20 rounded-full blur-[60px] animate-morph" style="animation-delay: -4s"></div>

        <!-- Floating dots -->
        <div class="absolute top-8 left-8 w-2 h-2 bg-white/20 rounded-full animate-float-slow"></div>
        <div class="absolute bottom-8 right-8 w-3 h-3 bg-accent-400/20 rounded-full animate-float-slow" style="animation-delay: -2s"></div>
        <div class="absolute top-1/2 left-[15%] w-1.5 h-1.5 bg-white/10 rounded-full animate-float-slow" style="animation-delay: -5s"></div>

        <div class="relative z-10">
          <h2 class="text-[28px] md:text-[40px] font-heading font-bold text-white">
            Ai un proiect de infrastructură?
          </h2>
          <p class="text-white/60 text-[16px] mt-4 max-w-lg mx-auto">
            Contactează-ne pentru o consultanță gratuită. Analizăm cerințele și îți oferim o soluție personalizată.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center mt-8">
            <a href="/contact" class="group inline-flex items-center justify-center gap-2 bg-accent-500 text-white px-8 py-4 rounded-full font-semibold text-[15px] hover:bg-accent-600 transition-all hover:shadow-lg relative overflow-hidden">
              <span class="relative z-10">Solicită consultanță gratuită</span>
              <svg class="w-4 h-4 relative z-10 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
              <div class="absolute inset-0 animate-shimmer"></div>
            </a>
            <a href="tel:+40700000000" class="inline-flex items-center justify-center gap-2 bg-white/10 backdrop-blur text-white px-8 py-4 rounded-full font-semibold text-[15px] border border-white/20 hover:bg-white/20 transition-all">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              Sună-ne acum
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<!-- Road canvas animation -->
<script is:inline>
(function() {
  const canvas = document.getElementById('road-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  let W, H, progress = 0, startTime = null;
  const DURATION = 8000;

  function resize() {
    W = canvas.width = canvas.offsetWidth * (window.devicePixelRatio || 1);
    H = canvas.height = canvas.offsetHeight * (window.devicePixelRatio || 1);
    ctx.scale(window.devicePixelRatio || 1, window.devicePixelRatio || 1);
  }

  function easeOutCubic(t) { return 1 - Math.pow(1 - t, 3); }
  function easeInOutQuad(t) { return t < 0.5 ? 2 * t * t : 1 - Math.pow(-2 * t + 2, 2) / 2; }

  function drawTerrain(w, h, p) {
    if (p < 0.05) return;
    const tp = Math.min(1, p / 0.15);
    ctx.globalAlpha = tp * 0.6;
    const grad = ctx.createLinearGradient(0, h * 0.3, 0, h);
    grad.addColorStop(0, '#1a3520');
    grad.addColorStop(0.4, '#2d5a1e');
    grad.addColorStop(0.7, '#3a6b28');
    grad.addColorStop(1, '#1a2e15');
    ctx.fillStyle = grad;

    ctx.beginPath();
    ctx.moveTo(0, h);
    for (let x = 0; x <= w; x += 2) {
      const nx = x / w;
      const y = h * 0.55
        + Math.sin(nx * 3) * h * 0.06
        + Math.sin(nx * 7 + 1) * h * 0.03
        + Math.cos(nx * 5 + 2) * h * 0.04;
      ctx.lineTo(x, y);
    }
    ctx.lineTo(w, h);
    ctx.closePath();
    ctx.fill();
    ctx.globalAlpha = 1;
  }

  function drawSky(w, h, p) {
    if (p < 0.02) return;
    const sp = Math.min(1, p / 0.1);
    const grad = ctx.createLinearGradient(0, 0, 0, h * 0.6);
    grad.addColorStop(0, `rgba(10, 22, 40, ${sp})`);
    grad.addColorStop(0.5, `rgba(15, 32, 53, ${sp * 0.9})`);
    grad.addColorStop(1, `rgba(20, 45, 65, ${sp * 0.4})`);
    ctx.fillStyle = grad;
    ctx.fillRect(0, 0, w, h * 0.6);
  }

  function drawRoadPerspective(w, h, p) {
    if (p < 0.1) return;
    const rp = easeOutCubic(Math.min(1, (p - 0.1) / 0.35));
    const vanishX = w * 0.6;
    const vanishY = h * 0.38;
    const roadW = w * 0.55;
    const roadEndW = w * 0.015;

    ctx.save();
    ctx.beginPath();
    const leftBot = vanishX - roadW / 2;
    const rightBot = vanishX + roadW / 2;
    const leftTop = vanishX - roadEndW;
    const rightTop = vanishX + roadEndW;

    const currentBot = h + 20;
    const currentTop = vanishY + (h - vanishY) * (1 - rp);

    const tlx = leftBot + (leftTop - leftBot) * rp;
    const trx = rightBot + (rightTop - rightBot) * rp;

    ctx.moveTo(leftBot, currentBot);
    ctx.lineTo(tlx, currentTop);
    ctx.lineTo(trx, currentTop);
    ctx.lineTo(rightBot, currentBot);
    ctx.closePath();

    const roadGrad = ctx.createLinearGradient(0, currentBot, 0, currentTop);
    roadGrad.addColorStop(0, 'rgba(45,45,50,0.95)');
    roadGrad.addColorStop(0.5, 'rgba(55,55,60,0.9)');
    roadGrad.addColorStop(1, 'rgba(40,40,45,0.7)');
    ctx.fillStyle = roadGrad;
    ctx.fill();

    if (rp > 0.3) {
      const lp = (rp - 0.3) / 0.7;
      ctx.strokeStyle = `rgba(255,255,255,${lp * 0.7})`;
      ctx.lineWidth = 1.5;
      ctx.setLineDash([]);
      ctx.beginPath();
      ctx.moveTo(leftBot + 15, currentBot);
      const elx = leftBot + 15 + (leftTop + 2 - (leftBot + 15)) * rp;
      ctx.lineTo(elx, currentTop);
      ctx.stroke();
      ctx.beginPath();
      ctx.moveTo(rightBot - 15, currentBot);
      const erx = rightBot - 15 + (rightTop - 2 - (rightBot - 15)) * rp;
      ctx.lineTo(erx, currentTop);
      ctx.stroke();
    }

    if (rp > 0.4) {
      const dp = (rp - 0.4) / 0.6;
      ctx.strokeStyle = `rgba(255,255,255,${dp * 0.5})`;
      ctx.lineWidth = 2;
      const segments = Math.floor(dp * 20);
      for (let i = 0; i < segments; i++) {
        const t1 = i / 20;
        const t2 = (i + 0.5) / 20;
        const y1 = currentBot + (currentTop - currentBot) * t1;
        const y2 = currentBot + (currentTop - currentBot) * t2;
        const x1 = vanishX;
        ctx.beginPath();
        ctx.moveTo(x1, y1);
        ctx.lineTo(x1, y2);
        ctx.stroke();
      }
    }

    ctx.restore();
  }

  function drawLayers(w, h, p) {
    if (p < 0.55) return;
    const lp = (p - 0.55) / 0.35;
    const cx = w * 0.15;
    const cy = h * 0.72;
    const lw = w * 0.32;
    const lh = h * 0.22;
    const boxAlpha = Math.min(1, lp * 2);

    ctx.save();
    ctx.globalAlpha = boxAlpha * 0.85;
    ctx.fillStyle = 'rgba(10, 22, 40, 0.75)';
    ctx.strokeStyle = 'rgba(100, 200, 255, 0.15)';
    ctx.lineWidth = 1;
    const r = 12;
    ctx.beginPath();
    ctx.roundRect(cx - 15, cy - lh * 0.1, lw + 30, lh + 20, r);
    ctx.fill();
    ctx.stroke();
    ctx.globalAlpha = boxAlpha;

    const layers = [
      { name: 'Teren natural', color: 'rgba(120,80,40,0.5)', h: 0.22 },
      { name: 'Fundație 20cm', color: 'rgba(180,160,120,0.55)', h: 0.18 },
      { name: 'Bază 15cm', color: 'rgba(160,170,180,0.6)', h: 0.15 },
      { name: 'Binder 6cm', color: 'rgba(80,80,80,0.7)', h: 0.1 },
      { name: 'Uzură 4cm', color: 'rgba(50,50,50,0.9)', h: 0.08 },
    ];

    let yOff = cy + lh * 0.85;
    const visibleLayers = Math.floor(lp * layers.length * 1.3);

    for (let i = 0; i < Math.min(visibleLayers, layers.length); i++) {
      const layer = layers[i];
      const layerH = lh * layer.h;
      yOff -= layerH;

      const layerP = Math.min(1, (lp * layers.length * 1.3 - i));
      ctx.globalAlpha = boxAlpha * layerP;

      const slopeL = 8 + i * 5;
      const slopeR = 8 + i * 5;

      ctx.fillStyle = layer.color;
      ctx.beginPath();
      ctx.moveTo(cx + slopeL, yOff + layerH);
      ctx.lineTo(cx, yOff);
      ctx.lineTo(cx + lw, yOff);
      ctx.lineTo(cx + lw - slopeR, yOff + layerH);
      ctx.closePath();
      ctx.fill();

      ctx.strokeStyle = 'rgba(255,255,255,0.15)';
      ctx.lineWidth = 0.5;
      ctx.stroke();

      ctx.fillStyle = 'rgba(255,255,255,0.5)';
      ctx.font = `${Math.max(9, w * 0.008)}px monospace`;
      ctx.fillText(layer.name, cx + lw + 18, yOff + layerH * 0.6);
    }

    if (lp > 0.85) {
      const mp = (lp - 0.85) / 0.15;
      ctx.globalAlpha = boxAlpha * mp;
      ctx.strokeStyle = '#d97706';
      ctx.lineWidth = 2;
      ctx.beginPath();
      ctx.moveTo(cx + lw * 0.45, yOff - 2);
      ctx.lineTo(cx + lw * 0.55, yOff - 2);
      ctx.stroke();

      ctx.strokeStyle = 'rgba(255,255,255,0.5)';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(cx - 2, yOff - 2);
      ctx.lineTo(cx + 4, yOff - 2);
      ctx.stroke();
      ctx.beginPath();
      ctx.moveTo(cx + lw - 4, yOff - 2);
      ctx.lineTo(cx + lw + 2, yOff - 2);
      ctx.stroke();

      ctx.fillStyle = 'rgba(100,200,255,0.5)';
      ctx.font = `bold ${Math.max(10, w * 0.009)}px monospace`;
      ctx.textAlign = 'center';
      ctx.fillText('7.00 m', cx + lw / 2, yOff - 10);
      ctx.textAlign = 'left';

      ctx.fillStyle = 'rgba(255,255,255,0.25)';
      ctx.font = `${Math.max(8, w * 0.007)}px monospace`;
      ctx.fillText('Profil transversal 1:50', cx, cy + lh + 12);
    }

    ctx.restore();
  }

  function drawGridOverlay(w, h, p) {
    if (p < 0.3) return;
    const gp = Math.min(1, (p - 0.3) / 0.3) * 0.04;
    ctx.strokeStyle = `rgba(100, 200, 255, ${gp})`;
    ctx.lineWidth = 0.5;
    const spacing = 50;
    for (let x = 0; x < w; x += spacing) {
      ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, h); ctx.stroke();
    }
    for (let y = 0; y < h; y += spacing) {
      ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(w, y); ctx.stroke();
    }
  }

  function draw(timestamp) {
    if (!startTime) startTime = timestamp;
    const elapsed = timestamp - startTime;
    progress = Math.min(1, elapsed / DURATION);

    const w = canvas.offsetWidth;
    const h = canvas.offsetHeight;

    ctx.clearRect(0, 0, W, H);
    ctx.save();

    drawSky(w, h, progress);
    drawTerrain(w, h, progress);
    drawGridOverlay(w, h, progress);
    drawRoadPerspective(w, h, progress);
    drawLayers(w, h, progress);

    ctx.restore();

    if (progress < 1) {
      requestAnimationFrame(draw);
    } else {
      floatLoop();
    }
  }

  let floatAngle = 0;
  function floatLoop() {
    floatAngle += 0.01;
    const w = canvas.offsetWidth;
    const h = canvas.offsetHeight;
    ctx.clearRect(0, 0, W, H);
    ctx.save();
    drawSky(w, h, 1);
    drawTerrain(w, h, 1);
    drawGridOverlay(w, h, 1);
    drawRoadPerspective(w, h, 1);
    drawLayers(w, h, 1);
    ctx.restore();
    requestAnimationFrame(floatLoop);
  }

  resize();
  window.addEventListener('resize', () => { resize(); if (progress >= 1) floatLoop(); });
  requestAnimationFrame(draw);
})();
</script>

<!-- Animations script -->
<script is:inline>
  // Counter animation
  function animateCounters() {
    const counters = document.querySelectorAll('.counter');
    counters.forEach(counter => {
      const target = parseInt(counter.dataset.target);
      const suffix = counter.dataset.suffix || '';
      const duration = 2000;
      const start = performance.now();

      function update(now) {
        const elapsed = now - start;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 4);
        const current = Math.floor(eased * target);
        counter.textContent = current + suffix;

        if (progress < 1) {
          requestAnimationFrame(update);
        } else {
          counter.textContent = target + suffix;
        }
      }

      requestAnimationFrame(update);
    });
  }

  // Trigger counters when visible
  const statsObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        animateCounters();
        statsObserver.disconnect();
      }
    });
  }, { threshold: 0.3 });

  document.querySelectorAll('.counter').forEach(el => {
    statsObserver.observe(el.closest('.grid'));
  });

  // Timeline progress animation
  const timelineObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const bar = entry.target.querySelector('.timeline-progress');
        if (bar) {
          bar.style.transition = 'width 2s cubic-bezier(0.4, 0, 0.2, 1)';
          bar.style.width = '100%';
        }
        timelineObserver.disconnect();
      }
    });
  }, { threshold: 0.3 });

  const timelineSection = document.querySelector('.timeline-progress');
  if (timelineSection) {
    timelineObserver.observe(timelineSection.closest('.relative'));
  }

  // 3D tilt effect on service cards
  document.querySelectorAll('.tilt-card').forEach(card => {
    card.addEventListener('mousemove', (e) => {
      const rect = card.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const centerX = rect.width / 2;
      const centerY = rect.height / 2;
      const rotateX = (y - centerY) / 20;
      const rotateY = (centerX - x) / 20;
      card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale(1.02)`;
    });

    card.addEventListener('mouseleave', () => {
      card.style.transform = 'perspective(1000px) rotateX(0) rotateY(0) scale(1)';
    });
  });

  // Parallax on scroll for floating elements
  let ticking = false;
  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(() => {
        const scrollY = window.scrollY;
        document.querySelectorAll('.parallax-layer').forEach(el => {
          const speed = parseFloat(el.dataset.speed) || 1;
          el.style.transform = `translateY(${scrollY * speed * 0.05}px)`;
        });
        ticking = false;
      });
      ticking = true;
    }
  });
</script>
