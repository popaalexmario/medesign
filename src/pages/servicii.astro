---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Lightbox from '../components/Lightbox.astro';

const services = [
  {
    slug: 'proiectare-drumuri',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l5.447 2.724A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" /></svg>`,
    title: 'Proiectare drumuri',
    desc: 'Proiecte tehnice complete pentru drumuri comunale, județene și naționale — de la studii topografice și geotehnice la detalii de execuție.',
    features: ['Drumuri comunale și județene', 'Intersecții și sensuri giratorii', 'Parcări și platforme', 'Piste de biciclete'],
    image: '/img/projects/proiectare-drumuri.png',
  },
  {
    slug: 'proiectare-poduri',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 17h18M3 17V9a2 2 0 012-2h4m10 10V9a2 2 0 00-2-2h-4m-4 0V5m0 2v10m0-10h4m-4 0H7" /></svg>`,
    title: 'Proiectare poduri, pasaje, pasarele',
    desc: 'Proiectare structuri de traversare pentru orice tip de obstacol — cursuri de apă, căi ferate, artere rutiere — cu soluții tehnice adaptate condițiilor specifice de amplasament.',
    features: ['Poduri rutiere și pietonale', 'Pasaje denivelate', 'Pasarele pietonale și cicliste', 'Podețe și podeturi'],
  },
  {
    slug: 'lucrari-sprijin-consolidari',
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0H5m14 0h2m-2 0h-2M5 21H3m2 0h2m0-16h6m-6 4h6m-6 4h6" /></svg>`,
    title: 'Proiectare lucrări de sprijin și consolidări',
    desc: 'Soluții tehnice pentru stabilizarea terenurilor instabile, consolidarea taluzurilor și protejarea infrastructurii existente împotriva alunecărilor și eroziunii.',
    features: ['Ziduri de sprijin și de câmp', 'Consolidări de taluzuri', 'Stabilizări de terenuri', 'Gabioane și ancore'],
  },
];
---

<Layout title="Servicii" description="Servicii complete de proiectare infrastructură: drumuri, poduri, pasaje, pasarele și lucrări de sprijin și consolidări.">
  <Header />

  <section class="pt-28 pb-8 bg-gradient-to-br from-brand-900 to-brand-700">
    <div class="container">
      <span class="text-accent-400 font-semibold text-[13px] uppercase tracking-widest" data-aos="fade-up">Serviciile noastre</span>
      <h1 class="text-[36px] md:text-[52px] font-heading font-extrabold text-white mt-3" data-aos="fade-up" data-aos-delay="50">
        Soluții complete de<br />proiectare infrastructură
      </h1>
      <p class="text-white/60 text-[17px] mt-4 max-w-xl" data-aos="fade-up" data-aos-delay="100">
        De la concept la implementare, acoperim întregul ciclu de viață al unui proiect de infrastructură.
      </p>
    </div>
  </section>

  <section class="section-padding bg-white">
    <div class="container space-y-10">
      {services.map((service, i) => (
        <div class={`flex flex-col ${i % 2 === 1 ? 'lg:flex-row-reverse' : 'lg:flex-row'} gap-8 items-center`} data-aos="fade-up">
          <div class="flex-1">
            <div class="w-14 h-14 bg-brand-500/10 rounded-2xl flex items-center justify-center text-brand-500 mb-4" set:html={service.icon} />
            <h2 class="text-[24px] md:text-[30px] font-heading font-bold text-brand-800">{service.title}</h2>
            <p class="text-steel-500 text-[15px] mt-3 leading-relaxed">{service.desc}</p>
            <ul class="mt-4 space-y-2">
              {service.features.map((f) => (
                <li class="flex items-center gap-3 text-steel-600 text-[14px]">
                  <svg class="w-4 h-4 text-accent-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  {f}
                </li>
              ))}
            </ul>
            <div class="flex items-center gap-3 mt-5">
              <a href={`/servicii/${service.slug === 'lucrari-sprijin-consolidari' ? 'lucrari-consolidare' : service.slug === 'proiectare-poduri' ? 'proiectare-poduri-pasaje' : service.slug}`} class="inline-flex items-center gap-2 bg-steel-100 text-brand-700 px-5 py-2.5 rounded-full font-semibold text-[14px] hover:bg-steel-200 transition-all">
                Detalii serviciu
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
              <a href="/contact" class="inline-flex items-center gap-2 bg-brand-500 text-white px-5 py-2.5 rounded-full font-semibold text-[14px] hover:bg-brand-600 transition-all">
                Solicită ofertă
              </a>
            </div>
          </div>
          <div class="flex-1">
            {service.image ? (
              <div class="relative rounded-3xl overflow-hidden shadow-xl group/img" data-lightbox>
                <img src={service.image} alt={service.title} class="w-full aspect-[4/3] object-cover hover:scale-105 transition-transform duration-700" loading="lazy" />
                <div class="absolute inset-0 bg-black/0 group-hover/img:bg-black/10 transition-colors flex items-center justify-center opacity-0 group-hover/img:opacity-100">
                  <div class="w-12 h-12 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center">
                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" />
                    </svg>
                  </div>
                </div>
              </div>
            ) : (
              <div class="bg-steel-100 rounded-3xl aspect-[4/3] flex items-center justify-center">
                <div class="text-steel-300 text-center">
                  <div class="w-16 h-16 mx-auto mb-3 rounded-2xl bg-steel-200 flex items-center justify-center" set:html={service.icon} />
                  <p class="text-[14px]">Imagine proiect</p>
                </div>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </section>

  <Lightbox />
  <Footer />
</Layout>
