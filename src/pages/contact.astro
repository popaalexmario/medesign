---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const contactInfo = [
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`,
    title: 'Adresă Sediu Social',
    value: 'Str. Avionului 26, Et. 1, Ap. B',
    sub: 'Sectorul 1, București',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>`,
    title: 'Telefon',
    value: '+40 746 784 156',
    sub: 'Apel gratuit în rețea',
    iconStyle: 'background-color:#dcfce7; color:#16a34a;',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>`,
    title: 'Email',
    value: 'office@me-design.ro',
    sub: 'Răspundem în max. 24h',
    iconStyle: 'background-color:#dbeafe; color:#2563eb;',
  },
];
---

<Layout title="Contact" description="Contactează ME Design pentru o consultanță gratuită în proiectare infrastructură.">
  <Header />

  <section class="pt-32 pb-16 bg-gradient-to-br from-brand-900 to-brand-700">
    <div class="container">
      <span class="text-accent-400 font-semibold text-[13px] uppercase tracking-widest" data-aos="fade-up">Contact</span>
      <h1 class="text-[36px] md:text-[52px] font-heading font-extrabold text-white mt-3" data-aos="fade-up" data-aos-delay="50">
        Hai să discutăm
      </h1>
      <p class="text-white/60 text-[17px] mt-4 max-w-xl" data-aos="fade-up" data-aos-delay="100">
        Ai un proiect de infrastructură? Completează formularul și te contactăm în cel mai scurt timp.
      </p>
    </div>
  </section>

  <section class="section-padding bg-white">
    <div class="container">
      <div class="grid lg:grid-cols-5 gap-12">
        <div class="lg:col-span-3" data-aos="fade-right">
          <h2 class="font-heading font-bold text-[24px] text-brand-800 mb-8">Trimite-ne un mesaj</h2>
          <form class="space-y-6" id="contact-form">
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-[14px] font-medium text-steel-700 mb-2">Nume complet *</label>
                <input type="text" id="name" name="name" required
                  class="w-full px-4 py-3 rounded-xl border border-steel-200 text-[15px] focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500 outline-none transition-all"
                  placeholder="Ion Popescu" />
              </div>
              <div>
                <label for="company" class="block text-[14px] font-medium text-steel-700 mb-2">Companie / Instituție</label>
                <input type="text" id="company" name="company"
                  class="w-full px-4 py-3 rounded-xl border border-steel-200 text-[15px] focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500 outline-none transition-all"
                  placeholder="Primăria / S.C. Exemplu" />
              </div>
            </div>
            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <label for="email" class="block text-[14px] font-medium text-steel-700 mb-2">Email *</label>
                <input type="email" id="email" name="email" required
                  class="w-full px-4 py-3 rounded-xl border border-steel-200 text-[15px] focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500 outline-none transition-all"
                  placeholder="email@exemplu.ro" />
              </div>
              <div>
                <label for="phone" class="block text-[14px] font-medium text-steel-700 mb-2">Telefon</label>
                <input type="tel" id="phone" name="phone"
                  class="w-full px-4 py-3 rounded-xl border border-steel-200 text-[15px] focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500 outline-none transition-all"
                  placeholder="+40 7XX XXX XXX" />
              </div>
            </div>
            <div>
              <label for="service" class="block text-[14px] font-medium text-steel-700 mb-2">Serviciu dorit</label>
              <select id="service" name="service"
                class="w-full px-4 py-3 rounded-xl border border-steel-200 text-[15px] focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500 outline-none transition-all bg-white text-steel-600">
                <option value="">Selectează serviciul</option>
                <option value="drumuri">Proiectare drumuri</option>
                <option value="poduri">Proiectare poduri, pasaje, pasarele</option>
                <option value="consolidari">Lucrări de sprijin și consolidări</option>
                <option value="altele">Altele</option>
              </select>
            </div>
            <div>
              <label for="message" class="block text-[14px] font-medium text-steel-700 mb-2">Descriere proiect *</label>
              <textarea id="message" name="message" rows="5" required
                class="w-full px-4 py-3 rounded-xl border border-steel-200 text-[15px] focus:ring-2 focus:ring-brand-500/20 focus:border-brand-500 outline-none transition-all resize-none"
                placeholder="Descrieți pe scurt proiectul pentru care aveți nevoie de servicii de proiectare..."></textarea>
            </div>
            <button type="submit"
              class="w-full sm:w-auto bg-brand-500 text-white px-8 py-4 rounded-full font-semibold text-[15px] hover:bg-brand-600 transition-all hover:shadow-lg hover:shadow-brand-500/25 flex items-center justify-center gap-2">
              Trimite mesajul
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" />
              </svg>
            </button>
          </form>
        </div>

        <div class="lg:col-span-2 space-y-6" data-aos="fade-left">
          <h2 class="font-heading font-bold text-[24px] text-brand-800 mb-8">Informații contact</h2>
          {contactInfo.map((item) => (
            <div class="glass-card rounded-2xl p-6 flex gap-4">
              <div class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0 bg-brand-500/10 text-brand-500" style={item.iconStyle ?? ''} set:html={item.icon} />
              <div>
                <h3 class="font-heading font-semibold text-[15px] text-brand-800">{item.title}</h3>
                <p class="text-steel-700 text-[15px] font-medium mt-0.5">{item.value}</p>
                <p class="text-steel-400 text-[13px] mt-0.5">{item.sub}</p>
              </div>
            </div>
          ))}

          <div class="bg-steel-100 rounded-2xl aspect-[4/3] flex items-center justify-center mt-6">
            <div class="text-steel-300 text-center">
              <svg class="w-12 h-12 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <p class="text-[14px]">Hartă Google Maps</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />

  <script>
    document.getElementById('contact-form')?.addEventListener('submit', function(e) {
      e.preventDefault();
      const f = e.target as HTMLFormElement;
      const name = (f.querySelector('#name') as HTMLInputElement).value;
      const company = (f.querySelector('#company') as HTMLInputElement).value;
      const email = (f.querySelector('#email') as HTMLInputElement).value;
      const phone = (f.querySelector('#phone') as HTMLInputElement).value;
      const service = (f.querySelector('#service') as HTMLSelectElement).value;
      const message = (f.querySelector('#message') as HTMLTextAreaElement).value;

      const subject = encodeURIComponent('Solicitare proiect – ME Design');
      const body = encodeURIComponent(
        `Nume: ${name}\n` +
        (company ? `Companie/Instituție: ${company}\n` : '') +
        `Email: ${email}\n` +
        (phone ? `Telefon: ${phone}\n` : '') +
        (service ? `Serviciu dorit: ${service}\n` : '') +
        `\nDescriere proiect:\n${message}`
      );

      window.location.href = `mailto:office@me-design.ro?subject=${subject}&body=${body}`;
    });
  </script>
</Layout>
