---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact" description="Contactează ME Design pentru o consultanță gratuită în proiectare infrastructură.">
  <Header />

  <section class="pt-32 pb-16 bg-gradient-to-br from-brand-900 to-brand-700">
    <div class="container">
      <span class="text-accent-400 font-semibold text-[13px] uppercase tracking-widest" data-aos="fade-up">Contact</span>
      <h1 class="text-[36px] md:text-[52px] font-heading font-extrabold text-white mt-3" data-aos="fade-up" data-aos-delay="50">
        Hai să discutăm
      </h1>
      <p class="text-white/60 text-[17px] mt-4 max-w-xl" data-aos="fade-up" data-aos-delay="100">
        Ai un proiect de infrastructură? Contactează-ne și îți răspundem în cel mai scurt timp.
      </p>
    </div>
  </section>

  <section class="section-padding bg-white">
    <div class="container max-w-2xl mx-auto">
      <h2 class="font-heading font-bold text-[24px] text-brand-800 mb-8" data-aos="fade-up">Informații contact</h2>

      <div class="space-y-4" data-aos="fade-up" data-aos-delay="50">
        <!-- Adresă -->
        <div class="glass-card rounded-2xl p-6 flex gap-4">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0 bg-brand-500/10 text-brand-500">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <div>
            <h3 class="font-heading font-semibold text-[15px] text-brand-800">Adresă Sediu Social</h3>
            <p class="text-steel-700 text-[15px] font-medium mt-0.5">Str. Avionului 26, Et. 1, Ap. B</p>
            <p class="text-steel-400 text-[13px] mt-0.5">Sectorul 1, București</p>
          </div>
        </div>

        <!-- Telefon -->
        <a href="tel:+40746784156" class="glass-card rounded-2xl p-6 flex gap-4 hover:shadow-lg transition-all group block">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0" style="background-color:#dcfce7; color:#16a34a;">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <div>
            <h3 class="font-heading font-semibold text-[15px] text-brand-800">Telefon</h3>
            <p class="text-green-600 group-hover:text-green-700 text-[15px] font-medium mt-0.5 underline underline-offset-2">+40 746 784 156</p>
            <p class="text-steel-400 text-[13px] mt-0.5">Apel gratuit în rețea</p>
          </div>
        </a>

        <!-- Email -->
        <a href={`mailto:office@me-design.ro?subject=${encodeURIComponent('Solicitare servicii proiectare – ME Design')}&body=${encodeURIComponent('Bună ziua,\n\nMă numesc: \nReprezint compania / instituția: \nFuncția mea: \nNr. de telefon de contact: \n\n---\n\nTip proiect dorit (drumuri / poduri / consolidări / altele): \nLocalizare proiect (județ / localitate): \nFaza de proiectare solicitată (SF / DALI / DTAC / PTE / altele): \nTermen estimat de finalizare dorit: \n\nDescriere scurtă a proiectului:\n\n\n---\n\nCu stimă,\n')}`} class="glass-card rounded-2xl p-6 flex gap-4 hover:shadow-lg transition-all group block">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center shrink-0" style="background-color:#dbeafe; color:#2563eb;">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <h3 class="font-heading font-semibold text-[15px] text-brand-800">Email</h3>
            <p class="text-brand-500 group-hover:text-brand-600 text-[15px] font-medium mt-0.5 underline underline-offset-2">office@me-design.ro</p>
            <p class="text-steel-400 text-[13px] mt-0.5">Răspundem în max. 24h</p>
          </div>
        </a>
      </div>

    </div>
  </section>

  <Footer />
</Layout>
